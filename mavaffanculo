class CDataCache
{
private:
   MqlRates    m_rates[];
   double      m_rsi[];
   double      m_rsiMa[];
   double      m_atr[];
   datetime    m_lastRatesTime;
   datetime    m_lastRSITime;
   datetime    m_lastATRTime;
   int         m_rsiHandle;
   int         m_atrHandle;
   int         m_lastRatesCount;
   
public:
   CDataCache() : m_lastRatesTime(0), m_lastRSITime(0), m_lastATRTime(0),
                  m_rsiHandle(INVALID_HANDLE), m_atrHandle(INVALID_HANDLE),
                  m_lastRatesCount(0) {}
   
   bool Init()
   {
      m_rsiHandle = iRSI(_Symbol, InpSignalTF, RSI_Period, PRICE_CLOSE);
      if(m_rsiHandle == INVALID_HANDLE) return false;
      
      // Se ATR_TF < InpSignalTF, il Strategy Tester sintetizza le barre del TF
      // inferiore in modo non deterministico (dipende dalle posizioni aperte).
      // Forziamo ATR_TF a InpSignalTF come minimo per garantire coerenza.
      ENUM_TIMEFRAMES effectiveATRTF = ATR_TF;
      if(ATR_TF != PERIOD_CURRENT && ATR_TF < InpSignalTF)
      {
         effectiveATRTF = (ENUM_TIMEFRAMES)InpSignalTF;
         PrintFormat("[WARN] ATR_TF (%d) < InpSignalTF (%d): forzato a InpSignalTF per evitare valori non deterministici nel tester", ATR_TF, InpSignalTF);
      }
      m_atrHandle = iATR(_Symbol, effectiveATRTF, ATR_Period);
      if(m_atrHandle == INVALID_HANDLE)
      {
         IndicatorRelease(m_rsiHandle);
         return false;
      }
      return true;
   }
   
   void Release()
   {
      if(m_rsiHandle != INVALID_HANDLE) { IndicatorRelease(m_rsiHandle); m_rsiHandle = INVALID_HANDLE; }
      if(m_atrHandle != INVALID_HANDLE) { IndicatorRelease(m_atrHandle); m_atrHandle = INVALID_HANDLE; }
      ArrayFree(m_rates);
      ArrayFree(m_rsi);
      ArrayFree(m_rsiMa);
      ArrayFree(m_atr);
   }
   
   bool GetRates(int needed, MqlRates &outRates[])
   {
      datetime t0 = iTime(_Symbol, InpSignalTF, 0);
      if(t0 == m_lastRatesTime && m_lastRatesCount >= needed)
      {
         ArrayCopy(outRates, m_rates);
         ArraySetAsSeries(outRates, true);
         return true;
      }
      
      ArrayResize(m_rates, 0);
      int copied = CopyRates(_Symbol, InpSignalTF, 0, needed, m_rates);
      if(copied <= 0) return false;
      
      ArraySetAsSeries(m_rates, true);
      m_lastRatesTime = t0;
      m_lastRatesCount = copied;
      ArrayCopy(outRates, m_rates);
      return true;
   }
   
   bool GetRSIData(int needed, double &outRSI[], double &outRSIMa[])
   {
      datetime t0 = iTime(_Symbol, InpSignalTF, 0);
      if(t0 == m_lastRSITime && (int)ArraySize(m_rsi) >= needed + RSI_MA_Period)
      {
         ArrayCopy(outRSI, m_rsi);
         ArrayCopy(outRSIMa, m_rsiMa);
         ArraySetAsSeries(outRSI, true);
         ArraySetAsSeries(outRSIMa, true);
         return true;
      }
      
      if(m_rsiHandle == INVALID_HANDLE) return false;
      
      int copyCount = needed + RSI_MA_Period + 10;
      ArrayResize(m_rsi, copyCount);
      ArraySetAsSeries(m_rsi, true);
      
      int copied = CopyBuffer(m_rsiHandle, 0, 0, copyCount, m_rsi);
      if(copied <= 0) return false;
      
      // Sostituisce EMPTY_VALUE (DBL_MAX) con 50.0 (valore neutro RSI).
      // EMPTY_VALUE appare nelle prime barre del backtest quando l'indicatore
      // non è ancora "caldo". Senza questo fix la somma va in overflow e
      // corrompe TUTTE le m_rsiMa[] per l'intero backtest — zero segnali.
      for(int i = 0; i < copied; i++)
         if(m_rsi[i] >= EMPTY_VALUE - 1.0 || m_rsi[i] < 0.0)
            m_rsi[i] = 50.0;
      
      ArrayResize(m_rsiMa, copied);
      ArraySetAsSeries(m_rsiMa, true);
      
      // Inizializza m_rsiMa a 50 (neutro) per le barre dove la SMA non è ancora calcolabile
      for(int i = 0; i < copied; i++) m_rsiMa[i] = 50.0;
      
      if(copied > RSI_MA_Period)
      {
         double sum = 0;
         for(int i = copied - 1; i >= copied - RSI_MA_Period; i--)
            sum += m_rsi[i];
         
         for(int i = copied - RSI_MA_Period - 1; i >= 0; i--)
         {
            sum += m_rsi[i];
            sum -= m_rsi[i + RSI_MA_Period];
            m_rsiMa[i] = sum / RSI_MA_Period;
         }
      }
      
      m_lastRSITime = t0;
      ArrayCopy(outRSI, m_rsi);
      ArrayCopy(outRSIMa, m_rsiMa);
      return true;
   }
   
   bool GetATR(int needed, double &outATR[])
   {
      // Nessuna cache per ATR: CopyBuffer ogni tick.
      // La cache ATR causava valori congelati/inconsistenti nel Strategy Tester
      // quando ATR_TF < InpSignalTF (es M5 su tester M15).
      if(m_atrHandle == INVALID_HANDLE) return false;
      
      int minNeeded = MathMax(needed, ATR_Period * 3 + 10);
      ArrayResize(m_atr, 0);
      int copied = CopyBuffer(m_atrHandle, 0, 0, minNeeded, m_atr);
      if(copied < 2) return false;
      
      ArraySetAsSeries(m_atr, true);
      ArrayCopy(outATR, m_atr);
      return true;
   }
   
   double GetLatestATR() 
   { 
      if((int)ArraySize(m_atr) < 2) return 0.0;
      return m_atr[1]; 
   }
   
   bool IsCrossUp(int shift) 
   { 
      if(shift + 1 >= (int)ArraySize(m_rsi)) return false;
      return (m_rsi[shift + 1] < m_rsiMa[shift + 1] && m_rsi[shift] >= m_rsiMa[shift]); 
   }
   
   bool IsCrossDown(int shift) 
   { 
      if(shift + 1 >= (int)ArraySize(m_rsi)) return false;
      return (m_rsi[shift + 1] > m_rsiMa[shift + 1] && m_rsi[shift] <= m_rsiMa[shift]); 
   }
   
   double GetRSI(int shift) { return (shift < (int)ArraySize(m_rsi) ? m_rsi[shift] : 0); }
   double GetRSISMA(int shift) { return (shift < (int)ArraySize(m_rsiMa) ? m_rsiMa[shift] : 0); }
};

class CLevelManager
{
private:
   double      m_levels[];
   int         m_count;
   string      m_loadedDate;
   bool        m_hasLevels;
   
   void Push(double level)
   {
      int n = (int)ArraySize(m_levels);
      ArrayResize(m_levels, n + 1);
      m_levels[n] = level;
      m_count = n + 1;
      m_hasLevels = true;
   }
   
   void AddLevelToArray(double price, double &arr[]) const
   {
      int n = (int)ArraySize(arr);
      ArrayResize(arr, n + 1);
      arr[n] = price;
   }
   
public:
   CLevelManager() : m_count(0), m_hasLevels(false) { ArrayResize(m_levels, 0); }
   
   void Clear() { ArrayResize(m_levels, 0); m_count = 0; m_hasLevels = false; }
   
