   }
}

void CTradeManager::ManagePositions(const CLevelManager &levels, CDataCache &cache, 
                                     PerformanceStats &stats)
{
   CleanupStates();
   if(PositionsTotal() <= 0) return;
   
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double atr = cache.GetLatestATR();
   
   string todayYMD = TimeToString(TimeCurrent(), TIME_DATE);
   StringReplace(todayYMD, ".", "-");
   
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(!PositionSelectByTicket(ticket)) continue;
      
      if(PositionGetString(POSITION_SYMBOL) != _Symbol || 
         (long)PositionGetInteger(POSITION_MAGIC) != (long)InpMagicNumber)
         continue;
      
      long type = PositionGetInteger(POSITION_TYPE);
      double vol = PositionGetDouble(POSITION_VOLUME);
      double entry = PositionGetDouble(POSITION_PRICE_OPEN);
      double sl = PositionGetDouble(POSITION_SL);
      double tp = PositionGetDouble(POSITION_TP);
      double profit = PositionGetDouble(POSITION_PROFIT);
      string comment = PositionGetString(POSITION_COMMENT);
      
      ENUM_SIGNAL_SETUP setup; ENUM_DIR dir;
      int anchorIdx, t1, t2, t3;
      string openDate;
      
      if(!ParseComment(comment, setup, dir, anchorIdx, t1, t2, t3, openDate)) continue;
      if(dir == DIR_NONE || anchorIdx < 0) continue;
      
      // =====================================================================
      // LOOKUP PREZZI DEI LIVELLI:
      // Usiamo sempre GetLevelsForDate(openDate) come fonte primaria — funziona
      // sia per il giorno corrente che per quelli storici.
      // Se la data non è nel database, usiamo i livelli correnti come fallback.
      // =====================================================================
      double effectiveAnchorPrice = 0.0;
      double effectiveT1Price     = 0.0;
      double effectiveT2Price     = 0.0;
      double effectiveT3Price     = 0.0;
      
      double dayLevels[];
      if(levels.GetLevelsForDate(openDate, dayLevels))
      {
         // CRITICO: GetLevelsForDate restituisce i livelli nell'ordine hardcoded
         // (discendente), ma gli indici nel commento si riferiscono all'array
         // ORDINATO ASCENDENTE (come fa LoadForDate). Bisogna ordinare prima.
         int nLvl = (int)ArraySize(dayLevels);
         for(int _i = 0; _i < nLvl - 1; _i++)
            for(int _j = _i + 1; _j < nLvl; _j++)
               if(dayLevels[_i] > dayLevels[_j])
               { double _tmp = dayLevels[_i]; dayLevels[_i] = dayLevels[_j]; dayLevels[_j] = _tmp; }
         
         if(anchorIdx >= 0 && anchorIdx < nLvl) effectiveAnchorPrice = dayLevels[anchorIdx];
         if(t1 >= 0 && t1 < nLvl) effectiveT1Price = dayLevels[t1];
         if(t2 >= 0 && t2 < nLvl) effectiveT2Price = dayLevels[t2];
         if(t3 >= 0 && t3 < nLvl) effectiveT3Price = dayLevels[t3];
      }
      
      // Fallback: se i prezzi non sono stati trovati, recuperali dai livelli CORRENTI
      // usando il prezzo corrente come riferimento (non l'entry, che potrebbe essere
      // molto lontano dal mercato attuale).
      if(effectiveT1Price <= 0 || (effectiveT3Price <= 0 && t3 >= 0) || tp == 0.0)
      {
         double refPrice = (type == POSITION_TYPE_BUY ? bid : ask);
         int nearIdx = levels.FindNearestToPrice(refPrice);
         if(nearIdx >= 0)
         {
            int ct1, ct2, ct3;
            if(levels.BuildTargets(dir, nearIdx, ct1, ct2, ct3))
            {
               if(effectiveT1Price <= 0 && ct1 >= 0) effectiveT1Price = levels.Get(ct1);
               if(effectiveT2Price <= 0 && ct2 >= 0) effectiveT2Price = levels.Get(ct2);
               if(effectiveT3Price <= 0 && ct3 >= 0) effectiveT3Price = levels.Get(ct3);
               
               if(tp == 0.0)
               {
                  double recoveredTP = 0.0;
                  if(ct3 >= 0) recoveredTP = levels.Get(ct3);
                  else if(ct2 >= 0) recoveredTP = levels.Get(ct2);
                  else if(ct1 >= 0) recoveredTP = levels.Get(ct1);
                  
                  if(recoveredTP > 0.0)
                  {
                     bool validTP = (dir == DIR_BUY  && recoveredTP > refPrice) ||
                                    (dir == DIR_SELL && recoveredTP < refPrice);
                     if(validTP)
                     {
                        recoveredTP = NormalizeDouble(recoveredTP, g_digits);
                        if(ModifySLTP(ticket, sl, recoveredTP))
                        {
                           tp = recoveredTP;
                           LogEx(LOG_INFO, StringFormat(
                              "Recovered TP #%I64u: entry=%.2f curr=%.2f nearLvl=%.2f TP=%.2f",
                              ticket, entry, refPrice, levels.Get(nearIdx), recoveredTP), "RECOVER");
                        }
                     }
                  }
               }
            }
         }
      }
      
      // =====================================================================
      // SANITY CHECK: annulla i target che sono dalla parte sbagliata dell'entry.
      // Un BUY deve avere T1/T2/T3 > entry, un SELL deve averli < entry.
      // Questo previene l'emergency close immediato quando il fallback recovery
      // assegna livelli scorretti (es. BUY con T3 sotto l'entry).
      // =====================================================================
      if(dir == DIR_BUY)
      {
         if(effectiveT1Price > 0 && effectiveT1Price <= entry) { effectiveT1Price = 0; effectiveT2Price = 0; effectiveT3Price = 0; }
         else if(effectiveT2Price > 0 && effectiveT2Price <= entry) { effectiveT2Price = 0; effectiveT3Price = 0; }
         else if(effectiveT3Price > 0 && effectiveT3Price <= entry) { effectiveT3Price = 0; }
      }
      else // DIR_SELL
      {
         if(effectiveT1Price > 0 && effectiveT1Price >= entry) { effectiveT1Price = 0; effectiveT2Price = 0; effectiveT3Price = 0; }
         else if(effectiveT2Price > 0 && effectiveT2Price >= entry) { effectiveT2Price = 0; effectiveT3Price = 0; }
         else if(effectiveT3Price > 0 && effectiveT3Price >= entry) { effectiveT3Price = 0; }
      }
      
      LogEx(LOG_DEBUG, StringFormat(
         "Pos #%I64u %s | entry=%.2f | T1=%.2f T2=%.2f T3=%.2f | SL=%.2f TP=%.2f",
         ticket, (dir==DIR_BUY?"BUY":"SELL"), entry,
         effectiveT1Price, effectiveT2Price, effectiveT3Price, sl, tp), "MANAGE");
      
      double current = (type == POSITION_TYPE_BUY ? bid : ask);
      
      // =====================================================================
      // FIX C: CHIUSURA DI EMERGENZA se il prezzo è andato oltre T3 ma non è
      // stato chiuso (gap, TP mancante, o T3 non era impostato).
      // Controlla anche T1 e T2 come fallback se T3 non è disponibile.
      // =====================================================================
      
      // Calcola l'età della posizione in minuti
      datetime openTime = (datetime)PositionGetInteger(POSITION_TIME);
      int posAgeMinutes = (int)((TimeCurrent() - openTime) / 60);
      bool inGracePeriod = (GracePeriodMinutes > 0 && posAgeMinutes < GracePeriodMinutes);
      
      if(!inGracePeriod)
      {
         // Emergency close: scatta solo fuori dalla finestra di grazia
         // e solo se il profitto minimo è soddisfatto (se impostato)
         bool emergencyClose = false;
         string emergencyReason = "";
         
         bool profitOK = (MinProfitForEmergencyClose <= 0.0 || profit >= MinProfitForEmergencyClose);
         
         if(profitOK)
         {
            if(effectiveT3Price > 0)
            {
               if((dir == DIR_BUY  && current >= effectiveT3Price) ||
                  (dir == DIR_SELL && current <= effectiveT3Price))
               {
                  emergencyClose = true;
                  emergencyReason = StringFormat("T3 manual close (gap/missing TP): price=%.2f T3=%.2f", current, effectiveT3Price);
               }
            }
            else if(effectiveT2Price > 0 && effectiveT3Price <= 0)
            {
               if((dir == DIR_BUY  && current >= effectiveT2Price) ||
                  (dir == DIR_SELL && current <= effectiveT2Price))
               {
                  emergencyClose = true;
                  emergencyReason = StringFormat("T2 close (no T3 available): price=%.2f T2=%.2f", current, effectiveT2Price);
               }
            }
            else if(effectiveT1Price > 0 && effectiveT2Price <= 0 && effectiveT3Price <= 0)
            {
               if((dir == DIR_BUY  && current >= effectiveT1Price) ||
                  (dir == DIR_SELL && current <= effectiveT1Price))
               {
                  emergencyClose = true;
                  emergencyReason = StringFormat("T1 close (no T2/T3 available): price=%.2f T1=%.2f", current, effectiveT1Price);
               }
            }
         }
         
         if(emergencyClose)
         {
            LogEx(LOG_INFO, StringFormat("Emergency close #%I64u: %s", ticket, emergencyReason), "MANAGE");
            if(CloseFull(ticket))
            {
               stats.grossProfit += profit;
               stats.tradesClosed++;
               continue;
            }
         }
      }
      else
      {
         LogEx(LOG_DEBUG, StringFormat(
            "Grace period #%I64u: age=%dm/%dm — emergency close e trailing sospesi",
            ticket, posAgeMinutes, GracePeriodMinutes), "MANAGE");
      }
      
      // =====================================================================
      // Exit su segnale RSI opposto (solo se in profitto)
      // =====================================================================
      if(UseOppositeDivergenceExit && profit > 0.0)
      {
         bool exitSignal = (dir == DIR_BUY && cache.IsCrossDown(1) && cache.GetRSI(1) > RSI_OB) ||
                          (dir == DIR_SELL && cache.IsCrossUp(1) && cache.GetRSI(1) < RSI_OS);
         
         if(exitSignal && CloseFull(ticket))
         {
            stats.grossProfit += profit;
            stats.tradesClosed++;
            continue;
         }
      }
      
      // =====================================================================
      // HEDGE PROTECTION: eseguito SEMPRE, anche durante grace period
      // Il hedge deve poter ripiazzare ordini e spostare SL a BE indipendentemente
      // =====================================================================
      if(UseHedgeProtection && !IsTarget1Hit(ticket))
      {
         int _hsi = FindStateIndex(ticket);
         if(_hsi >= 0)
         {
            double levelBuf = LevelBufferPoints * g_point;
            double hTrigger = 0.0;
            if(dir == DIR_SELL)
            {
               for(int _lk = 0; _lk < levels.Count(); _lk++)
                  if(levels.Get(_lk) > entry + levelBuf) { hTrigger = levels.Get(_lk); break; }
            }
            else
            {
               for(int _lk = levels.Count()-1; _lk >= 0; _lk--)
                  if(levels.Get(_lk) < entry - levelBuf) { hTrigger = levels.Get(_lk); break; }
            }
            if(hTrigger > 0)
            {
               ManageHedgePosition(m_states[_hsi].hedgeTicket, dir, hTrigger, vol);
               
               // Se prezzo raggiunge livello successivo al trigger → chiudi tutto
               double nextLevel = 0.0;
               if(dir == DIR_SELL)
               {
                  for(int _nl = 0; _nl < levels.Count(); _nl++)
                     if(levels.Get(_nl) > hTrigger + levelBuf) { nextLevel = levels.Get(_nl); break; }
                  if(nextLevel > 0 && current >= nextLevel - levelBuf)
                  {
                     LogEx(LOG_INFO, StringFormat("Hedge: prezzo %.2f >= livello successivo %.2f — chiudo tutto", current, nextLevel), "HEDGE");
                     if(PositionSelectByTicket(m_states[_hsi].hedgeTicket))
                     { CTrade _ct; _ct.SetExpertMagicNumber(InpMagicNumber); _ct.PositionClose(m_states[_hsi].hedgeTicket); }
                     else if(OrderSelect(m_states[_hsi].hedgeTicket))
                        CancelHedgeOrder(m_states[_hsi].hedgeTicket);
                     m_states[_hsi].hedgeTicket = 0;
                     CTrade _ct2; _ct2.SetExpertMagicNumber(InpMagicNumber);
                     _ct2.PositionClose(ticket);
                     continue;
                  }
               }
               else
               {
                  for(int _nl = levels.Count()-1; _nl >= 0; _nl--)
                     if(levels.Get(_nl) < hTrigger - levelBuf) { nextLevel = levels.Get(_nl); break; }
                  if(nextLevel > 0 && current <= nextLevel + levelBuf)
                  {
                     LogEx(LOG_INFO, StringFormat("Hedge: prezzo %.2f <= livello successivo %.2f — chiudo tutto", current, nextLevel), "HEDGE");
                     if(PositionSelectByTicket(m_states[_hsi].hedgeTicket))
                     { CTrade _ct; _ct.SetExpertMagicNumber(InpMagicNumber); _ct.PositionClose(m_states[_hsi].hedgeTicket); }
                     else if(OrderSelect(m_states[_hsi].hedgeTicket))
                        CancelHedgeOrder(m_states[_hsi].hedgeTicket);
                     m_states[_hsi].hedgeTicket = 0;
                     CTrade _ct2; _ct2.SetExpertMagicNumber(InpMagicNumber);
                     _ct2.PositionClose(ticket);
                     continue;
                  }
               }
            }
         }
      }
      
      // =====================================================================
      // Gestione SL dinamico (trailing a scalini sui livelli)
      // Sospeso durante il grace period per evitare BE immediato
      // =====================================================================
      if(inGracePeriod)
      {
         // Durante il grace period salta il trailing SL, ma gestisce il hedge
         if(UseHedgeProtection && !IsTarget1Hit(ticket))
         {
            int _hsi = FindStateIndex(ticket);
            if(_hsi >= 0)
            {
               double levelBuf = LevelBufferPoints * g_point;
               double hTrigger = 0.0;
               if(dir == DIR_SELL)
               {
                  for(int _lk = 0; _lk < levels.Count(); _lk++)
                     if(levels.Get(_lk) > entry + levelBuf) { hTrigger = levels.Get(_lk); break; }
               }
               else
               {
                  for(int _lk = levels.Count()-1; _lk >= 0; _lk--)
                     if(levels.Get(_lk) < entry - levelBuf) { hTrigger = levels.Get(_lk); break; }
               }
               if(hTrigger > 0)
                  ManageHedgePosition(m_states[_hsi].hedgeTicket, dir, hTrigger, vol);
            }
         }
         continue;
      }
      
      double newSL = sl;
      // FIX 3: Il TP NON viene riscritto da ManagePositions se già impostato (tp > 0)
      // Viene riscritto solo se tp==0 (e in quel caso usa effectiveT3Price oppure T1)
      double newTP = (tp > 0.0) ? tp : 
                     NormalizeDouble((effectiveT3Price > 0 ? effectiveT3Price : effectiveT1Price), g_digits);
      
      if(dir == DIR_BUY)
      {
         // Step 1: Superato T1 → registra hit
         if(effectiveT1Price > 0 && current >= effectiveT1Price && !IsTarget1Hit(ticket))
         {
            SetTarget1Hit(ticket, true);
            LogEx(LOG_INFO, StringFormat("T1 Hit BUY #%I64u: price=%.2f T1=%.2f", ticket, current, effectiveT1Price), "SL");
            // HEDGE: T1 raggiunto → cancella il BUY/SELL STOP hedge, da qui la vecchia logica gestisce
            if(UseHedgeProtection)
            {
               int _hsi = FindStateIndex(ticket);
               if(_hsi >= 0 && m_states[_hsi].hedgeTicket != 0)
                  CancelHedgeOrder(m_states[_hsi].hedgeTicket);
            }
         }
         
         // Step 2: Superato T1 → SL a Breakeven (entry + buffer)
         if(IsTarget1Hit(ticket) && !IsBreakevenDone(ticket))
         {
            double beLevel = NormalizeDouble(entry + BreakevenBufferPoints * g_point, g_digits);
            if(beLevel > newSL)
            {
               newSL = beLevel;
               SetBreakevenDone(ticket, true);
               LogEx(LOG_INFO, StringFormat("BE set BUY #%I64u: entry=%.2f BE=%.2f (was SL=%.2f)", ticket, entry, newSL, sl), "SL");
            }
         }
         
         // Step 3: Chiusura parziale a T1
         if(UsePartialCloseAtTarget1 && !IsPartialDone(ticket) && 
            effectiveT1Price > 0 && current >= effectiveT1Price)
         {
            double volStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
            double minVol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
            double closeVol = vol * (PartialClosePercent / 100.0);
            closeVol = MathFloor(closeVol / volStep) * volStep;
            
            if(closeVol >= minVol && closeVol < vol)
               ClosePartial(ticket, closeVol);
            SetPartialDone(ticket, true);
         }
         
         // FIX 1: Superato T2 → SL su T1 (lock profitto T1)
         // Prima era: "a metà strada tra T1 e T2" — ora è al superamento effettivo di T2
         if(effectiveT2Price > 0 && current >= effectiveT2Price && !IsTarget2Hit(ticket))
         {
            SetTarget2Hit(ticket, true);
            double slAtT1 = NormalizeDouble(effectiveT1Price, g_digits);
            if(slAtT1 > newSL)
            {
               newSL = slAtT1;
               LogEx(LOG_INFO, StringFormat("T2 Hit SELL #%I64u: price=%.2f T2=%.2f → newSL=%.2f (T1)", ticket, current, effectiveT2Price, newSL), "SL");
            }
         }
         
         // Mantieni SL su T1 anche se già segnato (protezione da oscillazioni)
         if(IsTarget2Hit(ticket) && effectiveT1Price > 0)
            newSL = MathMax(newSL, NormalizeDouble(effectiveT1Price, g_digits));
         
         // FIX 2: Superato T3 → SL su T2 (lock profitto T2)
         // Prima era: "a metà strada tra T2 e T3" — ora al superamento di T3
         // (in realtà T3 dovrebbe essere già chiuso dal broker/manuale sopra, 
         //  ma se il prezzo ci arriva lentamente senza gap, questo protegge)
         if(effectiveT3Price > 0 && current >= effectiveT3Price && effectiveT2Price > 0)
         {
            double slAtT2 = NormalizeDouble(effectiveT2Price, g_digits);
            newSL = MathMax(newSL, slAtT2);
         }
         
         // ATR Trailing attivo da T2 in su
         if(UseATRTrailing && atr > 0.0 && effectiveT2Price > 0 && current >= effectiveT2Price)
         {
            double atrSL = NormalizeDouble(current - (atr * ATR_TrailMult), g_digits);
            newSL = MathMax(newSL, atrSL);
         }
         
         // Applica modifica SL solo se migliora (solo in su per BUY)
         newSL = NormalizeDouble(newSL, g_digits);
         if(newSL > 0.0 && (sl <= 0.0 || newSL > sl + 2 * g_point))
            ModifySLTP(ticket, newSL, newTP);
      }
      else // DIR_SELL
      {
         // Step 1: Superato T1 (verso il basso) → registra hit
         if(effectiveT1Price > 0 && current <= effectiveT1Price && !IsTarget1Hit(ticket))
         {
            SetTarget1Hit(ticket, true);
            LogEx(LOG_INFO, StringFormat("T1 Hit SELL #%I64u: price=%.2f T1=%.2f", ticket, current, effectiveT1Price), "SL");
            // HEDGE: T1 raggiunto → cancella il BUY/SELL STOP hedge, da qui la vecchia logica gestisce
            if(UseHedgeProtection)
            {
               int _hsi = FindStateIndex(ticket);
               if(_hsi >= 0 && m_states[_hsi].hedgeTicket != 0)
                  CancelHedgeOrder(m_states[_hsi].hedgeTicket);
            }
         }
         
         // Step 2: Superato T1 → SL a Breakeven (entry + buffer, sopra entry per SELL)
         if(IsTarget1Hit(ticket) && !IsBreakevenDone(ticket))
         {
            // Per SELL: SL deve essere SOPRA entry (protezione dal rialzo)
            // Breakeven = entry + buffer = uscita a zero se il prezzo risale all'entry
            double beLevel = NormalizeDouble(entry + BreakevenBufferPoints * g_point, g_digits);
            if(newSL == 0.0 || beLevel < newSL)
            {
               newSL = beLevel;
               SetBreakevenDone(ticket, true);
               LogEx(LOG_INFO, StringFormat("BE set SELL #%I64u: entry=%.2f BE=%.2f (was SL=%.2f)", ticket, entry, newSL, sl), "SL");
            }
         }
         
         // Step 3: Chiusura parziale a T1
         if(UsePartialCloseAtTarget1 && !IsPartialDone(ticket) && 
            effectiveT1Price > 0 && current <= effectiveT1Price)
         {
            double volStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
            double minVol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
            double closeVol = vol * (PartialClosePercent / 100.0);
            closeVol = MathFloor(closeVol / volStep) * volStep;
            
            if(closeVol >= minVol && closeVol < vol)
               ClosePartial(ticket, closeVol);
            SetPartialDone(ticket, true);
         }
         
         // FIX 1: Superato T2 (verso il basso) → SL su T1 (lock profitto T1)
         if(effectiveT2Price > 0 && current <= effectiveT2Price && !IsTarget2Hit(ticket))
         {
            SetTarget2Hit(ticket, true);
            double slAtT1 = NormalizeDouble(effectiveT1Price, g_digits);
            if(newSL == 0.0 || slAtT1 < newSL)
            {
               newSL = slAtT1;
               LogEx(LOG_INFO, StringFormat("T2 Hit SELL #%I64u: price=%.2f T2=%.2f → newSL=%.2f (T1)", ticket, current, effectiveT2Price, newSL), "SL");
            }
         }
         
         // Mantieni SL su T1 anche se già segnato
         if(IsTarget2Hit(ticket) && effectiveT1Price > 0)
         {
            if(newSL == 0.0 || effectiveT1Price < newSL)
               newSL = NormalizeDouble(effectiveT1Price, g_digits);
         }
         
         // FIX 2: Superato T3 (verso il basso) → SL su T2
         if(effectiveT3Price > 0 && current <= effectiveT3Price && effectiveT2Price > 0)
         {
            double slAtT2 = NormalizeDouble(effectiveT2Price, g_digits);
            if(newSL == 0.0 || slAtT2 < newSL)
               newSL = slAtT2;
         }
         
         // ATR Trailing attivo da T2 in giù
         if(UseATRTrailing && atr > 0.0 && effectiveT2Price > 0 && current <= effectiveT2Price)
         {
            double atrSL = NormalizeDouble(current + (atr * ATR_TrailMult), g_digits);
            if(newSL == 0.0 || atrSL < newSL)
               newSL = atrSL;
         }
         
         // Applica modifica SL solo se migliora (solo in giù per SELL)
         newSL = NormalizeDouble(newSL, g_digits);
         if(newSL > 0.0 && (sl <= 0.0 || newSL < sl - 2 * g_point))
            ModifySLTP(ticket, newSL, newTP);
      }
      
   }
}

// ============================== SIGNAL DETECTION ===================
bool CheckRejectionSignal(const CLevelManager &levels, CDataCache &cache, SignalResult &sig)
{
   sig = SignalResult();
   if(!UseSetup_RejectionMomentum) return false;
   
   double touchBuf = TouchBufferPoints * g_point;
   int levelIdx = levels.FindNearestNearToClose(1, touchBuf);
   if(levelIdx < 0)
   {
      LogEx(LOG_DEBUG, StringFormat("REJ SKIP: nessun livello vicino a close=%.2f touchBuf=%.2f",
         iClose(_Symbol,InpSignalTF,1), touchBuf), "REJ");
      return false;
   }
   
   double close1 = iClose(_Symbol, InpSignalTF, 1);
   if(close1 == 0) return false;
   
   bool buyCross = cache.IsCrossUp(1);
   bool sellCross = cache.IsCrossDown(1);
   if(!buyCross && !sellCross)
   {
      LogEx(LOG_DEBUG, StringFormat("REJ SKIP: nessun crossover RSI | RSI[1]=%.2f SMA[1]=%.2f RSI[2]=%.2f SMA[2]=%.2f",
         cache.GetRSI(1), cache.GetRSISMA(1), cache.GetRSI(2), cache.GetRSISMA(2)), "REJ");
      return false;
   }
   
   int aboveCount = 0, belowCount = 0;
   int checkBars = MathMax(1, RejMinRSITrendBars);
   
   for(int i = 2; i < 2 + checkBars && i < 100; i++)
   {
      if(cache.GetRSI(i) > cache.GetRSISMA(i)) aboveCount++;
      if(cache.GetRSI(i) < cache.GetRSISMA(i)) belowCount++;
   }
   
   double levelBuf = LevelBufferPoints * g_point;
   double level = levels.Get(levelIdx);
   
   LogEx(LOG_DEBUG, StringFormat(
      "REJ CHECK: close=%.2f level=%.2f[%d] cross=%s aboveCount=%d belowCount=%d need=%d",
      close1, level, levelIdx,
      (sellCross?"SELL":"BUY"), aboveCount, belowCount, RejMinRSITrendBars), "REJ");
   
   if(AllowSell && sellCross && aboveCount >= RejMinRSITrendBars)
   {
      int attempts = 0;
      for(int s = 2; s <= RejLookbackBars + 1 && s < 100; s++)
      {
         double h = iHigh(_Symbol, InpSignalTF, s);
         double l = iLow(_Symbol, InpSignalTF, s);
         double c = iClose(_Symbol, InpSignalTF, s);
         if(h == 0 || l == 0 || c == 0) continue;
         
         bool touched = (l <= level + touchBuf && h >= level - touchBuf);
         bool nearCtx = (MathAbs(c - level) <= levels.NearDistance(levelIdx));
         
         if(!touched && !nearCtx) continue;
         if(c <= level + levelBuf) attempts++;
      }
      
      LogEx(LOG_DEBUG, StringFormat("REJ SELL: attempts=%d min=%d max=%d", attempts, RejMinFailedAttempts, RejMaxFailedAttempts), "REJ");
      if(attempts < RejMinFailedAttempts || attempts > RejMaxFailedAttempts)
      {
         LogEx(LOG_DEBUG, StringFormat("REJ SELL SKIP: attempts=%d fuori range [%d,%d]", attempts, RejMinFailedAttempts, RejMaxFailedAttempts), "REJ");
         return false;
      }
      if(UseLevelCloseFilter && close1 >= level - levelBuf)
      {
         LogEx(LOG_DEBUG, StringFormat("REJ SELL SKIP: LevelCloseFilter close=%.2f >= level-buf=%.2f", close1, level-levelBuf), "REJ");
         return false;
      }
      
      if(RejRequireCurrentBarNearLvl)
      {
         bool nearNow = levels.IsNear(close1, levelIdx) || 
                       levels.CandleTouches(1, levelIdx, touchBuf);
         if(!nearNow)
         {
            LogEx(LOG_DEBUG, StringFormat("REJ SELL SKIP: barra corrente non vicina al livello close=%.2f level=%.2f nearDist=%.2f", close1, level, levels.NearDistance(levelIdx)), "REJ");
            return false;
         }
      }
      
      sig.valid = true;
      sig.dir = DIR_SELL;
      sig.setup = SETUP_REJECTION;
      sig.anchorIdx = levelIdx;
      sig.reason = "Rejection SELL, attempts: " + IntegerToString(attempts);
      return true;
   }
   else if(sellCross && aboveCount < RejMinRSITrendBars)
      LogEx(LOG_DEBUG, StringFormat("REJ SELL SKIP: aboveCount=%d < minRSITrendBars=%d", aboveCount, RejMinRSITrendBars), "REJ");
   
   if(AllowBuy && buyCross && belowCount >= RejMinRSITrendBars)
   {
      int attempts = 0;
      for(int s = 2; s <= RejLookbackBars + 1 && s < 100; s++)
      {
         double h = iHigh(_Symbol, InpSignalTF, s);
         double l = iLow(_Symbol, InpSignalTF, s);
         double c = iClose(_Symbol, InpSignalTF, s);
         if(h == 0 || l == 0 || c == 0) continue;
         
         bool touched = (l <= level + touchBuf && h >= level - touchBuf);
         bool nearCtx = (MathAbs(c - level) <= levels.NearDistance(levelIdx));
         
         if(!touched && !nearCtx) continue;
         if(c >= level - levelBuf) attempts++;
      }
      
      LogEx(LOG_DEBUG, StringFormat("REJ BUY: attempts=%d min=%d max=%d", attempts, RejMinFailedAttempts, RejMaxFailedAttempts), "REJ");
      if(attempts < RejMinFailedAttempts || attempts > RejMaxFailedAttempts)
      {
         LogEx(LOG_DEBUG, StringFormat("REJ BUY SKIP: attempts=%d fuori range [%d,%d]", attempts, RejMinFailedAttempts, RejMaxFailedAttempts), "REJ");
         return false;
      }
      if(UseLevelCloseFilter && close1 <= level + levelBuf)
      {
         LogEx(LOG_DEBUG, StringFormat("REJ BUY SKIP: LevelCloseFilter close=%.2f <= level+buf=%.2f", close1, level+levelBuf), "REJ");
         return false;
      }
      
      if(RejRequireCurrentBarNearLvl)
      {
         bool nearNow = levels.IsNear(close1, levelIdx) || 
                       levels.CandleTouches(1, levelIdx, touchBuf);
         if(!nearNow)
         {
            LogEx(LOG_DEBUG, StringFormat("REJ BUY SKIP: barra corrente non vicina al livello close=%.2f level=%.2f nearDist=%.2f", close1, level, levels.NearDistance(levelIdx)), "REJ");
            return false;
         }
      }
      
      sig.valid = true;
      sig.dir = DIR_BUY;
      sig.setup = SETUP_REJECTION;
      sig.anchorIdx = levelIdx;
      sig.reason = "Rejection BUY, attempts: " + IntegerToString(attempts);
      return true;
   }
   else if(buyCross && belowCount < RejMinRSITrendBars)
      LogEx(LOG_DEBUG, StringFormat("REJ BUY SKIP: belowCount=%d < minRSITrendBars=%d", belowCount, RejMinRSITrendBars), "REJ");
   
   return false;
}

bool IsPivotHigh(const MqlRates &rates[], int i, int left, int right)
{
   if(i - right < 0 || i + left >= (int)ArraySize(rates)) return false;
   
   double center = rates[i].high;
   for(int k = 1; k <= left; k++)
      if(rates[i + k].high >= center) return false;
   
   for(int k = 1; k <= right; k++)
      if(rates[i - k].high > center) return false;
   
   return true;
}

bool IsPivotLow(const MqlRates &rates[], int i, int left, int right)
{
   if(i - right < 0 || i + left >= (int)ArraySize(rates)) return false;
   
   double center = rates[i].low;
   for(int k = 1; k <= left; k++)
      if(rates[i + k].low <= center) return false;
   
   for(int k = 1; k <= right; k++)
      if(rates[i - k].low < center) return false;
   
   return true;
}

bool FindLatestRegularDivergence(const CLevelManager &levels, const MqlRates &rates[], 
                                  const double &rsi[], DivergenceSignal &div)
{
   div = DivergenceSignal();
   
   int total = (int)ArraySize(rates);
   if(total < 50) return false;
   
   int maxScan = MathMin(PivotScanBars, total - (PivotLeftBars + PivotRightBars + 2));
   
   for(int recent = PivotRightBars + 1; recent < maxScan; recent++)
   {
      if(!IsPivotHigh(rates, recent, PivotLeftBars, PivotRightBars)) continue;
      
      for(int older = recent + MinSwingDistanceBars; 
          older <= MathMin(recent + MaxSwingDistanceBars, maxScan); older++)
      {
         if(!IsPivotHigh(rates, older, PivotLeftBars, PivotRightBars)) continue;
         
         double pr = rates[recent].high, po = rates[older].high;
         double rr = rsi[recent], ro = rsi[older];
         
         if(pr <= po + MinPriceSwingDiff) continue;
         if(rr >= ro - MinRSISwingDiff) continue;
         if(recent > DivRecentValidityBars) continue;
         
         int lvl = levels.FindNearestToPrice(pr);
         if(lvl < 0 || !levels.IsNear(pr, lvl)) continue;
         
         div.found = true;
         div.dir = DIR_SELL;
         div.pivotOlder = older;
         div.pivotRecent = recent;
         div.priceOlder = po;
         div.priceRecent = pr;
         div.rsiOlder = ro;
         div.rsiRecent = rr;
         div.levelIdx = lvl;
         return true;
      }
   }
   
   for(int recent = PivotRightBars + 1; recent < maxScan; recent++)
   {
      if(!IsPivotLow(rates, recent, PivotLeftBars, PivotRightBars)) continue;
      
      for(int older = recent + MinSwingDistanceBars;
          older <= MathMin(recent + MaxSwingDistanceBars, maxScan); older++)
      {
         if(!IsPivotLow(rates, older, PivotLeftBars, PivotRightBars)) continue;
         
         double pr = rates[recent].low, po = rates[older].low;
         double rr = rsi[recent], ro = rsi[older];
         
         if(pr >= po - MinPriceSwingDiff) continue;
         if(rr <= ro + MinRSISwingDiff) continue;
         if(recent > DivRecentValidityBars) continue;
         
         int lvl = levels.FindNearestToPrice(pr);
         if(lvl < 0 || !levels.IsNear(pr, lvl)) continue;
         
         div.found = true;
         div.dir = DIR_BUY;
         div.pivotOlder = older;
         div.pivotRecent = recent;
         div.priceOlder = po;
         div.priceRecent = pr;
         div.rsiOlder = ro;
         div.rsiRecent = rr;
         div.levelIdx = lvl;
         return true;
      }
   }
   
   return false;
}

bool CheckDivergenceSignal(const CLevelManager &levels, CDataCache &cache, 
                           MqlRates &rates[], SignalResult &sig)
{
   sig = SignalResult();
   if(!UseSetup_DivergenceReversal) return false;
   
   int needBars = MathMax(300, PivotScanBars + 50);
   
   if((int)ArraySize(rates) < needBars)
      if(!g_cache.GetRates(needBars, rates))
         return false;
   
   double rsi[], rsiMa[];
   if(!cache.GetRSIData(needBars, rsi, rsiMa)) return false;
   
   DivergenceSignal div;
   if(!FindLatestRegularDivergence(levels, rates, rsi, div))
   {
      LogEx(LOG_DEBUG, StringFormat("DIV SKIP: nessuna divergenza trovata in %d barre", (int)ArraySize(rates)), "DIV");
      return false;
   }
   
   double close1 = rates[1].close;
   double levelBuf = LevelBufferPoints * g_point;
   int levelIdx = div.levelIdx;
   
   if(div.dir == DIR_SELL && AllowSell)
   {
      if(close1 < levels.Get(levelIdx) - levelBuf)
      {
         sig.valid = true;
         sig.dir = DIR_SELL;
         sig.setup = SETUP_DIVERGENCE;
         sig.anchorIdx = levelIdx;
         sig.reason = "Bearish divergence";
         return true;
      }
   }
   
   if(div.dir == DIR_BUY && AllowBuy)
   {
      if(close1 > levels.Get(levelIdx) + levelBuf)
      {
         sig.valid = true;
         sig.dir = DIR_BUY;
         sig.setup = SETUP_DIVERGENCE;
         sig.anchorIdx = levelIdx;
         sig.reason = "Bullish divergence";
         return true;
      }
   }
   
   return false;
}

// ============================== FILTERS ============================
bool CheckSpreadFilter()
{
   if(MaxSpreadPoints <= 0) return true;
   
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   if(ask <= 0 || bid <= 0) return false;
   
   return ((ask - bid) / g_point <= MaxSpreadPoints);
}

bool CheckATRFilter(CDataCache &cache)
{
   if(!UseATRFilter) return true;
   
   // SEMPRE ricarica ATR fresco — non usare mai GetLatestATR() qui.
   // GetLatestATR() legge m_atr[] che può essere stato sovrascritto da
   // ManagePositions (trailing ATR) con un valore di un TF/barra diverso.
   double atrBuf[];
   int minBars = MathMax(ATR_Period * 3, 50);
   if(!cache.GetATR(minBars, atrBuf)) return false;
   double atr = cache.GetLatestATR();
   if(atr <= 0) return false;
   
   if(ATRMin > 0 && atr < ATRMin)
   {
      LogEx(LOG_DEBUG, StringFormat("ATR SKIP: atr=%.4f < ATRMin=%.4f", atr, ATRMin), "ATR");
      return false;
   }
   if(ATRMax > 0 && atr > ATRMax)
   {
      LogEx(LOG_DEBUG, StringFormat("ATR SKIP: atr=%.4f > ATRMax=%.4f", atr, ATRMax), "ATR");
      return false;
   }
   
   LogEx(LOG_DEBUG, StringFormat("ATR OK: atr=%.4f in [%.4f, %.4f] | ATR_Period=%d ATR_TF=%d", atr, ATRMin, ATRMax, ATR_Period, ATR_TF), "ATR");
   return true;
}

