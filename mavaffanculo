void CLevelManager::Draw()
{
   if(!DrawLevelsOnChart || !m_hasLevels) return;
   DeleteObjects();
   
   for(int i = 0; i < m_count; i++)
   {
      string hname = "ELS_LVL_" + m_loadedDate + "_" + IntegerToString(i);
      if(!ObjectCreate(0, hname, OBJ_HLINE, 0, 0, m_levels[i])) continue;
      
      ObjectSetInteger(0, hname, OBJPROP_COLOR, LevelColor);
      ObjectSetInteger(0, hname, OBJPROP_STYLE, LevelStyle);
      ObjectSetInteger(0, hname, OBJPROP_WIDTH, LevelWidth);
      ObjectSetInteger(0, hname, OBJPROP_BACK, false);
      ObjectSetInteger(0, hname, OBJPROP_SELECTABLE, false);
   }
   ChartRedraw(0);
}

void CLevelManager::DeleteObjects()
{
   for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
   {
      string nm = ObjectName(0, i);
      // Cancella solo le linee dei livelli giornalieri, NON le linee delle trade chiuse
      if(StringFind(nm, "ELS_LVL_") == 0)
         ObjectDelete(0, nm);
   }
}

double CLevelManager::NearDistance(int idx) const
{
   if(idx < 0 || idx >= m_count) return 0.0;
   
   double distPrev = (idx > 0) ? MathAbs(m_levels[idx] - m_levels[idx - 1]) : DBL_MAX;
   double distNext = (idx < m_count - 1) ? MathAbs(m_levels[idx + 1] - m_levels[idx]) : DBL_MAX;
   
   double baseDist = MathMin(distPrev, distNext);
   if(baseDist == DBL_MAX) baseDist = MathMax(distPrev, distNext);
   if(baseDist == DBL_MAX || baseDist <= 0.0) 
      baseDist = LevelBufferPoints * g_point * 2;
   
   return baseDist * (LevelNearPct / 100.0);
}

bool CLevelManager::IsNear(double price, int idx) const
{
   if(idx < 0 || idx >= m_count) return false;
   return (MathAbs(price - m_levels[idx]) <= NearDistance(idx));
}

bool CLevelManager::CandleTouches(int shift, int idx, double touchBuf) const
{
   double h = iHigh(_Symbol, InpSignalTF, shift);
   double l = iLow(_Symbol, InpSignalTF, shift);
   if(h == 0 || l == 0) return false;
   
   double L = m_levels[idx];
   return (l <= L + touchBuf && h >= L - touchBuf);
}

int CLevelManager::FindNearestToPrice(double price) const
{
   double best = DBL_MAX;
   int bestIdx = -1;
   
   for(int i = 0; i < m_count; i++)
   {
      double d = MathAbs(price - m_levels[i]);
      if(d < best) { best = d; bestIdx = i; }
   }
   return bestIdx;
}

int CLevelManager::FindTouchedClosestToClose(int shift, double touchBuf) const
{
   double c = iClose(_Symbol, InpSignalTF, shift);
   if(c == 0) return -1;
   
   double best = DBL_MAX;
   int bestIdx = -1;
   
   for(int i = 0; i < m_count; i++)
   {
      if(!CandleTouches(shift, i, touchBuf)) continue;
      double d = MathAbs(c - m_levels[i]);
      if(d < best) { best = d; bestIdx = i; }
   }
   return bestIdx;
}

int CLevelManager::FindNearestNearToClose(int shift, double touchBuf) const
{
   double c = iClose(_Symbol, InpSignalTF, shift);
   if(c == 0) return -1;
   
   double best = DBL_MAX;
   int bestIdx = -1;
   
   for(int i = 0; i < m_count; i++)
   {
      if(!IsNear(c, i) && !CandleTouches(shift, i, touchBuf)) continue;
      double d = MathAbs(c - m_levels[i]);
      if(d < best) { best = d; bestIdx = i; }
   }
   return bestIdx;
}

bool CLevelManager::BuildTargets(ENUM_DIR dir, int anchorIdx, int &t1, int &t2, int &t3) const
{
   t1 = t2 = t3 = -1;
   if(anchorIdx < 0 || anchorIdx >= m_count) return false;
   
   if(dir == DIR_BUY)
   {
      if(anchorIdx + 1 >= m_count) return false;
      t1 = anchorIdx + 1;
      // Se T2/T3 non esistono (livelli finiti), rimangono su T1.
      // Il trailing ATR gestisce l'uscita oltre l'ultimo livello.
      t2 = (anchorIdx + 2 < m_count) ? anchorIdx + 2 : t1;
      t3 = (anchorIdx + 3 < m_count) ? anchorIdx + 3 : t2;
      return true;
   }
   else if(dir == DIR_SELL)
   {
      if(anchorIdx - 1 < 0) return false;
      t1 = anchorIdx - 1;
      // Se T2/T3 non esistono (livelli finiti), rimangono su T1.
      // Il trailing ATR gestisce l'uscita oltre l'ultimo livello.
      t2 = (anchorIdx - 2 >= 0) ? anchorIdx - 2 : t1;
      t3 = (anchorIdx - 3 >= 0) ? anchorIdx - 3 : t2;
      return true;
   }
   return false;
}

// ============================== TRADE MANAGER IMPLEMENTATION =========
void CTradeManager::CleanupStates()
{
   for(int i = (int)ArraySize(m_states) - 1; i >= 0; i--)
   {
      if(!PositionSelectByTicket(m_states[i].ticket))
      {
         // HEDGE: se la posizione è chiusa e c'è ancora un hedge pending, cancellalo
         if(UseHedgeProtection && m_states[i].hedgeTicket != 0)
            CancelHedgeOrder(m_states[i].hedgeTicket);
         
         for(int j = i; j < (int)ArraySize(m_states) - 1; j++)
            m_states[j] = m_states[j + 1];
         ArrayResize(m_states, (int)ArraySize(m_states) - 1);
      }
   }
}

int CTradeManager::FindStateIndex(ulong ticket) const
{
   for(int i = 0; i < (int)ArraySize(m_states); i++)
      if(m_states[i].ticket == ticket) return i;
   return -1;
}

bool CTradeManager::IsPartialDone(ulong ticket) const
{
   int idx = FindStateIndex(ticket);
   return (idx >= 0 && m_states[idx].partialDone);
}

void CTradeManager::SetPartialDone(ulong ticket, bool done)
{
   int idx = FindStateIndex(ticket);
   if(idx < 0)
   {
      int n = (int)ArraySize(m_states);
      ArrayResize(m_states, n + 1);
      m_states[n] = TradeState(ticket);
      m_states[n].partialDone = done;
   }
   else
      m_states[idx].partialDone = done;
}

