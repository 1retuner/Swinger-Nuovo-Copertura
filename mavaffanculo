double CTradeManager::NormalizeLots(double lots)
{
   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double maxLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   double lotStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   
   lots = MathFloor(lots / lotStep) * lotStep;
   lots = MathMax(minLot, MathMin(maxLot, lots));
   
   double marginRequired;
   if(!OrderCalcMargin(ORDER_TYPE_BUY, _Symbol, lots, 
                       SymbolInfoDouble(_Symbol, SYMBOL_ASK), marginRequired))
      return 0.0;
   
   double freeMargin = AccountInfoDouble(ACCOUNT_MARGIN_FREE);
   if(marginRequired > freeMargin * 0.95)
   {
      lots = lots * (freeMargin * 0.95 / marginRequired);
      lots = MathFloor(lots / lotStep) * lotStep;
      lots = MathMax(minLot, lots);
   }
   return lots;
}

double CTradeManager::CalculateLotSize(double slDistance, double atr)
{
   double lots = InpFixedLots;
   
   switch(InpMMMode)
   {
      case MM_FIXED:
         lots = InpFixedLots;
         break;
         
      case MM_PERCENT_RISK:
      {
         double balance = AccountInfoDouble(ACCOUNT_BALANCE);
         double riskAmount = balance * (InpRiskPercent / 100.0);
         double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
         double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
         
         if(tickValue > 0 && tickSize > 0 && slDistance > 0)
         {
            double ticksAtRisk = slDistance / tickSize;
            lots = riskAmount / (ticksAtRisk * tickValue);
         }
         break;
      }
      
      case MM_KELLY_HALF:
      {
         double kellyPct = (InpKellyWinRate * InpKellyPayoff - (1 - InpKellyWinRate)) / InpKellyPayoff;
         kellyPct = MathMax(0, kellyPct) * 0.5;
         
         double balance = AccountInfoDouble(ACCOUNT_BALANCE);
         double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
         double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
         
         if(tickValue > 0 && tickSize > 0 && slDistance > 0)
         {
            double ticksAtRisk = slDistance / tickSize;
            lots = (balance * kellyPct) / (ticksAtRisk * tickValue);
         }
         break;
      }
   }
   return NormalizeLots(lots);
}

string CTradeManager::BuildComment(ENUM_SIGNAL_SETUP setup, ENUM_DIR dir, 
                                   int anchorIdx, int t1, int t2, int t3,
                                   const string &openDate)
{
   // Formato breve per stare sotto i 31 char di MT5: "ELS|s|d|a|t1|t2|t3|YYYYMMDD"
   // Esempio: "ELS|2|-1|7|6|5|4|20260204" = 25 chars max
   string shortDate = openDate;
   StringReplace(shortDate, "-", ""); // "2026-02-04" -> "20260204"
   return "ELS|" + IntegerToString((int)setup) + "|" + IntegerToString((int)dir) + "|" +
          IntegerToString(anchorIdx) + "|" + IntegerToString(t1) + "|" +
          IntegerToString(t2) + "|" + IntegerToString(t3) + "|" + shortDate;
}

bool CTradeManager::ParseComment(const string &comment, ENUM_SIGNAL_SETUP &setup,
                                  ENUM_DIR &dir, int &anchorIdx, int &t1, int &t2, int &t3,
                                  string &openDate)
{
   string parts[];
   int n = StringSplit(comment, '|', parts);
   if(n < 8 || parts[0] != "ELS") return false;
   
   setup   = (ENUM_SIGNAL_SETUP)StringToInteger(parts[1]);
   dir     = (ENUM_DIR)StringToInteger(parts[2]);
   anchorIdx = (int)StringToInteger(parts[3]);
   t1      = (int)StringToInteger(parts[4]);
   t2      = (int)StringToInteger(parts[5]);
   t3      = (int)StringToInteger(parts[6]);
   // Riconverti YYYYMMDD -> YYYY-MM-DD
   string d = parts[7];
   if(StringLen(d) == 8)
      openDate = StringSubstr(d,0,4) + "-" + StringSubstr(d,4,2) + "-" + StringSubstr(d,6,2);
   else
      openDate = d; // fallback per commenti vecchi con data già formattata
   return true;
}

void CTradeManager::DrawTradeLevels(ulong ticket, ENUM_SIGNAL_SETUP setup, ENUM_DIR dir,
                                     int anchorIdx, int t1, int t2, int t3)
{
   if(!EnableTradeDrawing) return;
   
   color clr = (setup == SETUP_REJECTION ? clrOrange : clrPurple);
   string base = "ELS_TRADE_" + IntegerToString(ticket) + "_";
   
   if(!PositionSelectByTicket(ticket)) return;
   
   double entry = PositionGetDouble(POSITION_PRICE_OPEN);
   
   ObjectCreate(0, base + "ENTRY", OBJ_HLINE, 0, 0, entry);
   ObjectSetInteger(0, base + "ENTRY", OBJPROP_COLOR, clr);
   ObjectSetInteger(0, base + "ENTRY", OBJPROP_STYLE, STYLE_SOLID);
   ObjectSetInteger(0, base + "ENTRY", OBJPROP_WIDTH, 2);
}

void CTradeManager::DeleteTradeLevels(ulong ticket)
{
   string base = "ELS_TRADE_" + IntegerToString(ticket) + "_";
   for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
   {
      string nm = ObjectName(0, i);
      if(StringFind(nm, base) == 0)
         ObjectDelete(0, nm);
   }
}

bool CTradeManager::Open(const SignalResult &sig, const CLevelManager &levels, double atr, const string &openDate)
{
   if(!sig.valid) return false;
   
   // ReversalMode: inverte la direzione del segnale prima di qualsiasi calcolo.
   // SELL diventa BUY e viceversa. SL/TP/entry vengono calcolati sulla direzione invertita.
   // Usare SOLO per test/ricerca — non in live trading senza validazione statistica.
   SignalResult effectiveSig = sig;
   if(ReversalMode)
      effectiveSig.dir = (sig.dir == DIR_SELL) ? DIR_BUY : DIR_SELL;
   
   datetime barTime = iTime(_Symbol, InpSignalTF, 0);
   if(g_lastTradeBarTime == barTime) return false;
   
   int openCount = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong t = PositionGetTicket(i);
      if(t == 0) continue;
      if(!PositionSelectByTicket(t)) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if((long)(long)PositionGetInteger(POSITION_MAGIC) != (long)InpMagicNumber) continue;
      // Escludi le posizioni hedge dal conteggio MaxSimultaneousTrades
      string posComment = PositionGetString(POSITION_COMMENT);
      if(StringFind(posComment, "ELS_HEDGE") >= 0) continue;
      openCount++;
   }
   
   if(openCount >= MaxSimultaneousTrades) return false;
   
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double entry = (effectiveSig.dir == DIR_BUY ? ask : bid);
   
   // Calcola i target partendo dal livello più vicino all'ENTRY REALE,
   // non dall'anchor del segnale. Il segnale può essere rilevato su una
   // barra precedente, mentre l'entry avviene tick dopo a un prezzo diverso.
   // Es: segnale su close a 4851, entry eseguita a 5047 → target da 5044, non da 4851.
   int effectiveAnchorIdx = levels.FindNearestToPrice(entry);
   if(effectiveAnchorIdx < 0) effectiveAnchorIdx = effectiveSig.anchorIdx;
   
   int t1, t2, t3;
   // Prova prima dall'entry level; se non va (es. siamo al bordo della griglia),
   // fallback sull'anchor originale del segnale
   if(!levels.BuildTargets(effectiveSig.dir, effectiveAnchorIdx, t1, t2, t3))
      if(!levels.BuildTargets(effectiveSig.dir, effectiveSig.anchorIdx, t1, t2, t3)) return false;
   
   double anchorPrice = levels.Get(effectiveAnchorIdx);
   double t1Price = (t1 >= 0 ? levels.Get(t1) : 0.0);
   double t2Price = (t2 >= 0 ? levels.Get(t2) : 0.0);
   double t3Price = (t3 >= 0 ? levels.Get(t3) : 0.0);
   
   // Usa effectiveAnchorIdx come anchor nel commento (per recupero corretto)
   int anchorIdxForComment = effectiveAnchorIdx;
   
   double levelBuf = LevelBufferPoints * g_point;
   double minSLDist = MinInitialSLPoints * g_point;
   double freezeDist = g_freezeLevelPoints * g_point;
   
   // Per il calcolo SL usiamo il livello sul LATO PERDENTE rispetto all'entry:
   // BUY → il livello più alto SOTTO l'entry (supporto da proteggere)
   // SELL → il livello più basso SOPRA l'entry (resistenza da proteggere)
   // Con UseHedgeProtection: il hedge order va a L+1, lo SL della posizione va a L+2.
   double slLevelPrice  = 0.0; // L+1 (hedge trigger / SL classico)
   double slLevelPrice2 = 0.0; // L+2 (SL reale con hedge attivo)
   if(effectiveSig.dir == DIR_BUY)
   {
      // Cerca i due livelli più alti SOTTO entry
      int found = 0;
      for(int _k = levels.Count() - 1; _k >= 0; _k--)
      {
         if(levels.Get(_k) < entry - levelBuf)
         {
            if(found == 0) { slLevelPrice  = levels.Get(_k); found++; }
            else           { slLevelPrice2 = levels.Get(_k); break; }
         }
      }
      if(slLevelPrice  <= 0) slLevelPrice  = levels.Get(effectiveAnchorIdx > 0 ? effectiveAnchorIdx - 1 : 0);
      if(slLevelPrice2 <= 0) slLevelPrice2 = slLevelPrice; // fallback: stesso livello
   }
   else
   {
      // Cerca i due livelli più bassi SOPRA entry
      int found = 0;
      for(int _k = 0; _k < levels.Count(); _k++)
      {
         if(levels.Get(_k) > entry + levelBuf)
         {
            if(found == 0) { slLevelPrice  = levels.Get(_k); found++; }
            else           { slLevelPrice2 = levels.Get(_k); break; }
         }
      }
      if(slLevelPrice  <= 0) slLevelPrice  = levels.Get(effectiveAnchorIdx + 1 < levels.Count() ? effectiveAnchorIdx + 1 : effectiveAnchorIdx);
      if(slLevelPrice2 <= 0) slLevelPrice2 = slLevelPrice; // fallback: stesso livello
   }
   
   // Con hedge attivo usa L+2 come SL effettivo della posizione
   double effectiveSLLevel = UseHedgeProtection ? slLevelPrice2 : slLevelPrice;
   
   double sl = 0.0;
   if(effectiveSig.dir == DIR_BUY)
   {
      // SL = il più conservativo tra: distanza minima da entry e livello sotto l'entry
      // Con UseHedgeProtection: effectiveSLLevel = L+2 (hedge a L+1 fa da primo paracadute)
      double slFromMinDist = entry - minSLDist - freezeDist;
      double slFromLevel   = (effectiveSLLevel > 0 ? effectiveSLLevel - levelBuf - freezeDist : slFromMinDist);
      sl = MathMax(slFromMinDist, slFromLevel); // MathMax = più vicino all'entry (più stretto)
      if(sl >= entry - 10 * g_point) sl = entry - 10 * g_point;
   }
   else
   {
      double slFromMinDist = entry + minSLDist + freezeDist;
      double slFromLevel   = (effectiveSLLevel > 0 ? effectiveSLLevel + levelBuf + freezeDist : slFromMinDist);
      sl = MathMin(slFromMinDist, slFromLevel); // MathMin = più vicino all'entry (più stretto)
      if(sl <= entry + 10 * g_point) sl = entry + 10 * g_point;
   }
   
   // FIX 3: TP SEMPRE su T3 se disponibile, altrimenti T2, altrimenti T1
   // Non viene più riscritto da ManagePositions se già valido
   double tp = 0.0;
   if(t3 >= 0 && t3Price > 0)      tp = t3Price;
   else if(t2 >= 0 && t2Price > 0) tp = t2Price;
   else if(t1 >= 0 && t1Price > 0) tp = t1Price;
   
   double minDist = MathMax(g_stopsLevelPoints, g_freezeLevelPoints) * g_point;
   
   if(effectiveSig.dir == DIR_BUY)
   {
      if(sl >= entry - minDist) sl = entry - minDist - 2 * g_point;
      if(tp > 0 && tp <= entry + minDist) tp = entry + minDist + 2 * g_point;
   }
   else
   {
      if(sl <= entry + minDist) sl = entry + minDist + 2 * g_point;
      if(tp > 0 && tp >= entry - minDist) tp = entry - minDist - 2 * g_point;
   }
   
   sl = NormalizeDouble(sl, g_digits);
   tp = NormalizeDouble(tp, g_digits);
   
   double slDist = MathAbs(entry - sl);
   double lots = CalculateLotSize(slDist, atr);
   if(lots <= 0) return false;
   
   string comment = BuildComment(effectiveSig.setup, effectiveSig.dir, anchorIdxForComment, t1, t2, t3, openDate);
   
   bool ok = (effectiveSig.dir == DIR_BUY) ? 
             m_trade.Buy(lots, _Symbol, 0.0, sl, tp, comment) :
             m_trade.Sell(lots, _Symbol, 0.0, sl, tp, comment);
   
   if(!ok) return false;
   
   ulong newTicket = m_trade.ResultOrder();
   
   LogEx(LOG_INFO, StringFormat(
      "Open %s #%I64u: entry=%.2f anchorLvl=%.2f T1=%.2f T2=%.2f T3=%.2f SL=%.2f TP=%.2f",
      (effectiveSig.dir==DIR_BUY?"BUY":"SELL"), newTicket,
      entry, anchorPrice, t1Price, t2Price, t3Price, sl, tp), "OPEN");
   
   // HEDGE PROTECTION: piazza il BUY/SELL STOP al livello L+1 con stessa size
   if(UseHedgeProtection && slLevelPrice > 0)
   {
      ulong hTicket = PlaceHedgeOrder(effectiveSig.dir, slLevelPrice, lots);
      // Salva il ticket hedge nello stato della posizione
      int si = (int)m_states.Size();
      // Lo stato viene aggiunto dalla logica standard, aggiorniamo dopo
      // Usiamo un array globale temporaneo per associare ticket→hedgeTicket
      // (lo stato viene popolato in OnTradeTransaction)
      // Salviamo in un buffer pending da applicare al prossimo FindState
      if(hTicket > 0)
      {
         // Cerca lo stato appena aggiunto e assegna hedgeTicket
         for(int _si = (int)ArraySize(m_states)-1; _si >= 0; _si--)
         {
            if(m_states[_si].ticket == newTicket)
            {
               m_states[_si].hedgeTicket = hTicket;
               LogEx(LOG_INFO, StringFormat("Hedge #%I64u associato a posizione #%I64u", hTicket, newTicket), "HEDGE");
               break;
            }
         }
      }
   }
   
   g_lastTradeBarTime = barTime;
   g_stats.tradesOpened++;
   
   DrawTradeLevels(newTicket, effectiveSig.setup, effectiveSig.dir, anchorIdxForComment, t1, t2, t3);
   return true;
}

bool CTradeManager::ModifySLTP(ulong ticket, double sl, double tp)
{
   if(!PositionSelectByTicket(ticket)) return false;
   
   double oldSL = PositionGetDouble(POSITION_SL);
   double oldTP = PositionGetDouble(POSITION_TP);
   
   if(MathAbs(oldSL - sl) < 2 * g_point && MathAbs(oldTP - tp) < 2 * g_point)
      return true;
   
   bool ok = m_trade.PositionModify(ticket, sl, tp);
   if(!ok)
      LogEx(LOG_ERROR, StringFormat(
         "ModifySLTP FAILED #%I64u: SL %.2f→%.2f TP %.2f→%.2f | retcode=%d err=%d ask=%.2f bid=%.2f",
         ticket, oldSL, sl, oldTP, tp,
         m_trade.ResultRetcode(),
         GetLastError(),
         SymbolInfoDouble(_Symbol, SYMBOL_ASK),
         SymbolInfoDouble(_Symbol, SYMBOL_BID)), "SL");
   else
      LogEx(LOG_INFO, StringFormat(
         "ModifySLTP OK #%I64u: SL %.2f→%.2f TP=%.2f",
         ticket, oldSL, sl, tp), "SL");
   return ok;
}

