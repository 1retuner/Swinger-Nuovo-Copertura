void LogEx(ENUM_LOG_LEVEL level, const string msg, const string context = "")
{
   if(!EnableLogs) return;
   if(level > InpLogLevel) return;
   
   string prefix;
   switch(level)
   {
      case LOG_ERROR: prefix = "[ERR]"; break;
      case LOG_WARN:  prefix = "[WRN]"; break;
      case LOG_INFO:  prefix = "[INF]"; break;
      case LOG_DEBUG: prefix = "[DBG]"; break;
   }
   
   string fullMsg = StringFormat("%s %s | %s | %s", 
                    prefix, TimeToString(TimeCurrent(), TIME_SECONDS), context, msg);
   
   Print(fullMsg);
   
   if(level == LOG_ERROR && InpVisualAlerts)
      Alert("Enaria ERROR: " + msg);
}

