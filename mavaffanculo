struct PerformanceStats
{
   datetime    startTime;
   int         totalSignals;
   int         tradesOpened;
   int         tradesClosed;
   double      grossProfit;
   double      grossLoss;
   double      maxDrawdown;
   double      maxDrawdownPct;
   double      peakEquity;
   
   PerformanceStats() : startTime(0), totalSignals(0), tradesOpened(0),
                        tradesClosed(0), grossProfit(0), grossLoss(0),
                        maxDrawdown(0), maxDrawdownPct(0), peakEquity(0) {}
                        
   void UpdateEquity()
   {
      double equity = AccountInfoDouble(ACCOUNT_EQUITY);
      if(equity > peakEquity || peakEquity == 0) 
         peakEquity = equity;
      
      double dd = peakEquity - equity;
      if(dd > maxDrawdown) 
      {
         maxDrawdown = dd;
         maxDrawdownPct = (peakEquity > 0 ? dd / peakEquity * 100 : 0);
      }
   }
   
   void PrintReport()
   {
      Print("=== EnariaLevelSwinger Performance Report ===");
      Print("Start Time: ", TimeToString(startTime, TIME_DATE|TIME_SECONDS));
      Print("Total Signals: ", totalSignals);
      Print("Trades Opened: ", tradesOpened);
      Print("Trades Closed: ", tradesClosed);
      Print("Gross Profit: $", DoubleToString(grossProfit, 2));
      Print("Gross Loss: $", DoubleToString(grossLoss, 2));
      Print("Net P/L: $", DoubleToString(grossProfit - grossLoss, 2));
      Print("Max Drawdown: $", DoubleToString(maxDrawdown, 2), " (", DoubleToString(maxDrawdownPct, 2), "%)");
      
      if(tradesClosed > 0)
      {
         double totalPnL = grossProfit + grossLoss;
         if(totalPnL > 0)
         {
            double winRate = (grossProfit / totalPnL) * 100.0;
            Print("Win Rate: ", DoubleToString(winRate, 2), "%");
         }
         double avgTrade = (grossProfit - grossLoss) / tradesClosed;
         Print("Average Trade: $", DoubleToString(avgTrade, 2));
      }
      Print("=============================================");
   }
};

