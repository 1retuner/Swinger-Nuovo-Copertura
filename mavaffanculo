// Chiude tutte le posizioni dell'EA e blocca i nuovi segnali fino al prossimo reset
void CloseAllEAPositions(const string reason)
{
   CTrade t;
   t.SetExpertMagicNumber(InpMagicNumber);
   t.SetDeviationInPoints(SlippagePoints);
   t.SetTypeFillingBySymbol(_Symbol);
   
   int closed = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if((long)PositionGetInteger(POSITION_MAGIC) != (long)InpMagicNumber) continue;
      
      // Cancella le linee grafiche della trade prima di chiuderla
      string base = "ELS_TRADE_" + IntegerToString(ticket) + "_";
      for(int _i = ObjectsTotal(0) - 1; _i >= 0; _i--)
      {
         string nm = ObjectName(0, _i);
         if(StringFind(nm, base) == 0) ObjectDelete(0, nm);
      }
      if(t.PositionClose(ticket))
      {
         closed++;
         if(EnableTradeDrawing)
         {
            string prefix = "ELS_TRADE_" + IntegerToString(ticket) + "_";
            for(int j = ObjectsTotal(0) - 1; j >= 0; j--)
            {
               string nm = ObjectName(0, j);
               if(StringFind(nm, prefix) == 0)
                  ObjectDelete(0, nm);
            }
         }
      }
      else
         LogEx(LOG_ERROR, StringFormat("Failed to close #%I64u: retcode=%d", ticket, t.ResultRetcode()), "EQUITY_TP");
   }
   
   LogEx(LOG_INFO, StringFormat("%s — closed %d positions", reason, closed), "EQUITY_TP");
}

bool CheckEquityTP()
{
   if(!UseEquityTP || EquityTPPercent <= 0.0) return false;
   if(PositionsTotal() <= 0) return false;
   
   // Conta solo le posizioni di questo EA
   int eaPositions = 0;
   double floatingProfit = 0.0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong t = PositionGetTicket(i);
      if(t == 0 || !PositionSelectByTicket(t)) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;
      if((long)PositionGetInteger(POSITION_MAGIC) != (long)InpMagicNumber) continue;
      eaPositions++;
      floatingProfit += PositionGetDouble(POSITION_PROFIT);
   }
   if(eaPositions == 0) return false;
   
   // Baseline: primo tick con posizioni aperte, o dopo un reset
   if(g_equityTPBaseline <= 0.0)
      g_equityTPBaseline = AccountInfoDouble(ACCOUNT_BALANCE);
   
   double profitPct = (floatingProfit / g_equityTPBaseline) * 100.0;
   
   if(profitPct >= EquityTPPercent)
   {
      LogEx(LOG_INFO, StringFormat(
         "Equity TP triggered: profit=%.2f (%.2f%% of baseline %.2f)",
         floatingProfit, profitPct, g_equityTPBaseline), "EQUITY_TP");
      
      CloseAllEAPositions(StringFormat("Equity TP %.1f%%", EquityTPPercent));
      
      // Resetta la baseline per il prossimo ciclo
      g_equityTPBaseline = 0.0;
      return true;
   }
   return false;
}



// ============================== HEDGE PROTECTION ==============================

// Piazza un ordine BUY STOP (per coprire SELL) o SELL STOP (per coprire BUY)
// al livello SL_LEVEL con SL a HedgeSLPoints nella direzione opposta
// Ritorna il ticket dell'ordine pending (0 = fallito)
ulong PlaceHedgeOrder(ENUM_DIR mainDir, double triggerLevel, double lots)
{
   LogEx(LOG_INFO, StringFormat("PlaceHedgeOrder CALLED: dir=%s trigger=%.2f lots=%.2f enabled=%s",
      mainDir==DIR_SELL?"SELL":"BUY", triggerLevel, lots, UseHedgeProtection?"YES":"NO"), "HEDGE");
   if(!UseHedgeProtection) return 0;
   if(triggerLevel <= 0 || lots <= 0) return 0;
   
   double hedgeSL = HedgeSLPoints * g_point;
   double minDist = MathMax(g_stopsLevelPoints, g_freezeLevelPoints) * g_point;
   
   CTrade trade;
   trade.SetExpertMagicNumber(InpMagicNumber);
   trade.SetDeviationInPoints(SlippagePoints);
   
   bool ok = false;
   if(mainDir == DIR_SELL)
   {
      // Copre SELL → piazza BUY STOP sopra
      double sl = NormalizeDouble(triggerLevel - hedgeSL, g_digits);
      double tp = 0; // nessun TP automatico, gestito da ManageHedge
      if(sl >= triggerLevel - minDist) sl = triggerLevel - minDist - g_point;
      ok = trade.BuyStop(lots, NormalizeDouble(triggerLevel, g_digits), _Symbol, sl, tp,
                         ORDER_TIME_GTC, 0, "ELS_HEDGE_BS");
   }
   else
   {
      // Copre BUY → piazza SELL STOP sotto
      double sl = NormalizeDouble(triggerLevel + hedgeSL, g_digits);
      double tp = 0;
      if(sl <= triggerLevel + minDist) sl = triggerLevel + minDist + g_point;
      ok = trade.SellStop(lots, NormalizeDouble(triggerLevel, g_digits), _Symbol, sl, tp,
                          ORDER_TIME_GTC, 0, "ELS_HEDGE_SS");
   }
   
   if(!ok)
   {
      LogEx(LOG_WARN, StringFormat("PlaceHedgeOrder FAILED: dir=%s trigger=%.2f lots=%.2f err=%d",
         mainDir==DIR_SELL?"SELL":"BUY", triggerLevel, lots, GetLastError()), "HEDGE");
      return 0;
   }
   
   ulong ticket = trade.ResultOrder();
   LogEx(LOG_INFO, StringFormat("PlaceHedgeOrder OK: %s STOP #%I64u trigger=%.2f lots=%.2f SL=%.2f",
      mainDir==DIR_SELL?"BUY":"SELL", ticket, triggerLevel, lots,
      triggerLevel - (mainDir==DIR_SELL ? hedgeSL : -hedgeSL)), "HEDGE");
   return ticket;
}

// Cancella un ordine pending hedge o chiude la posizione se già triggerata
void CancelHedgeOrder(ulong &hedgeTicket)
{
   if(hedgeTicket == 0) return;
   
   CTrade trade;
   trade.SetExpertMagicNumber(InpMagicNumber);
   
   if(OrderSelect(hedgeTicket))
   {
      // Ancora pending → cancella
      if(trade.OrderDelete(hedgeTicket))
         LogEx(LOG_INFO, StringFormat("CancelHedgeOrder (pending) OK: #%I64u", hedgeTicket), "HEDGE");
      else
         LogEx(LOG_WARN, StringFormat("CancelHedgeOrder (pending) FAILED: #%I64u err=%d", hedgeTicket, GetLastError()), "HEDGE");
   }
   else if(PositionSelectByTicket(hedgeTicket))
   {
      // Già triggerato come posizione → chiudi
      if(trade.PositionClose(hedgeTicket))
         LogEx(LOG_INFO, StringFormat("CancelHedgeOrder (posizione) chiusa: #%I64u", hedgeTicket), "HEDGE");
      else
         LogEx(LOG_WARN, StringFormat("CancelHedgeOrder (posizione) FAILED: #%I64u err=%d", hedgeTicket, GetLastError()), "HEDGE");
   }
   hedgeTicket = 0;
}

// Gestisce il ciclo completo del hedge per una posizione principale:
// 1. Se hedgeTicket==0 → ripiazza il pending order (hedge mancante)
// 2. Se pending → controlla solo che esista ancora
// 3. Se posizione attiva → sposta SL a BE dopo HedgeMinProfitPoints punti
// 4. Se posizione chiusa → ripiazza il pending order
void ManageHedgePosition(ulong &hedgeTicket, ENUM_DIR mainDir, double triggerLevel, double lots)
{
   // --- Caso 0: hedgeTicket mancante → ripiazza subito ---
   if(hedgeTicket == 0)
   {
      LogEx(LOG_INFO, StringFormat("Hedge mancante per trigger=%.2f — ripiazzo", triggerLevel), "HEDGE");
      hedgeTicket = PlaceHedgeOrder(mainDir, triggerLevel, lots);
      return;
   }
   
   // --- Caso 1: ancora pending order (non triggerato) → niente da fare ---
   if(OrderSelect(hedgeTicket)) return;
   
   // --- Caso 2: posizione aperta ---
   if(PositionSelectByTicket(hedgeTicket))
   {
      double hedgeEntry   = PositionGetDouble(POSITION_PRICE_OPEN);
      double currentSL    = PositionGetDouble(POSITION_SL);
      // Per hedge BUY (copre SELL) usiamo ASK; per hedge SELL (copre BUY) usiamo BID
      double currentPrice = (mainDir == DIR_SELL)
                            ? SymbolInfoDouble(_Symbol, SYMBOL_ASK)
                            : SymbolInfoDouble(_Symbol, SYMBOL_BID);
      
      double moveThreshold = HedgeMinProfitPoints * g_point;
      if(moveThreshold <= 0) return;
      
      bool shouldBE = false;
      double bePrice = NormalizeDouble(hedgeEntry, g_digits);
      
      if(mainDir == DIR_SELL) // hedge è BUY → in profitto quando prezzo sale
         shouldBE = (currentPrice >= hedgeEntry + moveThreshold);
      else                    // hedge è SELL → in profitto quando prezzo scende
         shouldBE = (currentPrice <= hedgeEntry - moveThreshold);
      
      // SL già a BE o migliore → skip
      bool alreadyBE = (mainDir == DIR_SELL)
                       ? (currentSL >= bePrice - g_point)
                       : (currentSL <= bePrice + g_point && currentSL > 0);
      
      if(shouldBE && !alreadyBE)
      {
         double minDist = MathMax(g_stopsLevelPoints, g_freezeLevelPoints) * g_point;
         bool slValid = (mainDir == DIR_SELL)
                        ? (bePrice < currentPrice - minDist)
                        : (bePrice > currentPrice + minDist);
         if(slValid)
         {
            CTrade trade;
            trade.SetExpertMagicNumber(InpMagicNumber);
            if(trade.PositionModify(hedgeTicket, bePrice, 0))
               LogEx(LOG_INFO, StringFormat(
                  "Hedge #%I64u SL→BE %.2f (price=%.2f entry=%.2f threshold=%.1f pts)",
                  hedgeTicket, bePrice, currentPrice, hedgeEntry, moveThreshold/g_point), "HEDGE");
            else
               LogEx(LOG_WARN, StringFormat(
                  "Hedge #%I64u SL→BE FAILED: bePrice=%.2f price=%.2f minDist=%.2f err=%d",
                  hedgeTicket, bePrice, currentPrice, minDist, GetLastError()), "HEDGE");
         }
      }
      return;
   }
   
   // --- Caso 3: né pending né posizione → è stato chiuso (SL o BE) → ripiazza ---
   ulong oldTicket = hedgeTicket;
   hedgeTicket = 0;
   ulong newTicket = PlaceHedgeOrder(mainDir, triggerLevel, lots);
   hedgeTicket = newTicket;
   LogEx(LOG_INFO, StringFormat("Hedge #%I64u chiuso (SL/BE) — ripiazzato #%I64u a %.2f (ok=%s)",
      oldTicket, newTicket, triggerLevel, newTicket>0?"SI":"NO"), "HEDGE");
}

// ============================== RSI VISUAL FUNCTIONS ==============================

void RSIWindow_DeleteObjects()
{
   for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
   {
      string nm = ObjectName(0, i);
      if(StringFind(nm, g_rsiObjPrefix) == 0)
         ObjectDelete(0, nm);
   }
}

bool RSIWindow_FindSubWindow()
{
   for(int w = 1; w < ChartGetInteger(0, CHART_WINDOWS_TOTAL); w++)
   {
      for(int k = 0; k < ChartIndicatorsTotal(0, w); k++)
      {
         string nm = ChartIndicatorName(0, w, k);
         if(StringFind(nm, "RSI") >= 0 && StringFind(nm, IntegerToString(RSI_Period)) >= 0)
         {
            g_rsiSubWindow = w;
            return true;
         }
      }
   }
   return false;
}

void RSIWindow_Init()
{
   if(!EnableRSIWindow) return;
   // Crea handle RSI sul TF del segnale e aggiungilo al chart (crea sottofinestra)
   if(g_rsiVisualHandle == INVALID_HANDLE)
      g_rsiVisualHandle = iRSI(_Symbol, InpSignalTF, RSI_Period, PRICE_CLOSE);
   if(g_rsiVisualHandle == INVALID_HANDLE) return;
   // Aggiunge alla sottofinestra 1 (MT5 la crea se non esiste)
   if(!RSIWindow_FindSubWindow())
   {
      ChartIndicatorAdd(0, (int)ChartGetInteger(0, CHART_WINDOWS_TOTAL), g_rsiVisualHandle);
      Sleep(200);
      RSIWindow_FindSubWindow();
   }
}

void RSIWindow_Release()
{
   RSIWindow_DeleteObjects();
   if(g_rsiVisualHandle != INVALID_HANDLE)
   {
      if(g_rsiSubWindow >= 0)
         ChartIndicatorDelete(0, g_rsiSubWindow, ChartIndicatorName(0, g_rsiSubWindow, 0));
      IndicatorRelease(g_rsiVisualHandle);
      g_rsiVisualHandle = INVALID_HANDLE;
   }
   g_rsiSubWindow = -1;
}

void RSIWindow_DrawCrossMarkers(const double &rsi[], const double &rsiMa[], int total)
{
   if(g_rsiSubWindow < 0) return;
   int limit = MathMin(total - 2, PivotScanBars * 3);
   int count = 0;
   for(int i = 1; i < limit; i++)
   {
      if(rsi[i] <= 0 || rsiMa[i] <= 0) continue;
      if(rsi[i+1] <= 0 || rsiMa[i+1] <= 0) continue;
      bool crossUp   = (rsi[i+1] < rsiMa[i+1] && rsi[i] >= rsiMa[i]);
      bool crossDown = (rsi[i+1] > rsiMa[i+1] && rsi[i] <= rsiMa[i]);
      if(!crossUp && !crossDown) continue;
      datetime t = iTime(_Symbol, InpSignalTF, i);
      if(t == 0) continue;
      
      string nm  = g_rsiObjPrefix + "CRS_" + IntegerToString((int)t);
      string lbl = g_rsiObjPrefix + "LBL_" + IntegerToString((int)t);
      color  clr = crossUp ? clrLime : clrRed;
      string txt = crossUp ? "Bull" : "Bear";
      int arrow  = crossUp ? 233 : 234;
      double yA  = crossUp ? rsi[i] - 5.0 : rsi[i] + 5.0;
      double yL  = crossUp ? rsi[i] - 10.0 : rsi[i] + 10.0;
      
      if(!ObjectCreate(0, nm, OBJ_ARROW, g_rsiSubWindow, t, yA)) continue;
      ObjectSetInteger(0, nm, OBJPROP_ARROWCODE, arrow);
      ObjectSetInteger(0, nm, OBJPROP_COLOR, clr);
      ObjectSetInteger(0, nm, OBJPROP_WIDTH, 2);
      ObjectSetString(0,  nm, OBJPROP_TOOLTIP, txt);
      
      ObjectCreate(0, lbl, OBJ_TEXT, g_rsiSubWindow, t, yL);
      ObjectSetString(0,  lbl, OBJPROP_TEXT, txt);
      ObjectSetInteger(0, lbl, OBJPROP_COLOR, clr);
      ObjectSetInteger(0, lbl, OBJPROP_FONTSIZE, 7);
      ObjectSetInteger(0, lbl, OBJPROP_ANCHOR, crossUp ? ANCHOR_TOP : ANCHOR_BOTTOM);
      count++;
   }
}

void RSIWindow_DrawDivergences(const double &rsi[], const MqlRates &rates[], int total)
{
   if(g_rsiSubWindow < 0) return;
   int maxScan = MathMin(PivotScanBars, total - (PivotLeftBars + PivotRightBars + 2));
   int dc = 0;

   // Bearish: prezzo HH, RSI LH
   for(int recent = PivotRightBars + 1; recent < maxScan; recent++)
   {
      if(!IsPivotHigh(rates, recent, PivotLeftBars, PivotRightBars)) continue;
      if(recent > DivRecentValidityBars) continue;
      if(rsi[recent] <= 0) continue;
      for(int older = recent + MinSwingDistanceBars;
          older <= MathMin(recent + MaxSwingDistanceBars, maxScan); older++)
      {
         if(!IsPivotHigh(rates, older, PivotLeftBars, PivotRightBars)) continue;
         if(rsi[older] <= 0) continue;
         double pr = rates[recent].high, po = rates[older].high;
         double rr = rsi[recent],        ro = rsi[older];
         if(pr <= po + MinPriceSwingDiff) continue;
         if(rr >= ro - MinRSISwingDiff)  continue;
         datetime t1 = iTime(_Symbol, InpSignalTF, older);
         datetime t2 = iTime(_Symbol, InpSignalTF, recent);
         if(t1 == 0 || t2 == 0) break;
         string nm = g_rsiObjPrefix + "DVB_" + IntegerToString(dc++);
         ObjectCreate(0, nm, OBJ_TREND, g_rsiSubWindow, t1, ro, t2, rr);
         ObjectSetInteger(0, nm, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, nm, OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, nm, OBJPROP_RAY_RIGHT, false);
         ObjectSetInteger(0, nm, OBJPROP_RAY_LEFT,  false);
         ObjectSetString(0,  nm, OBJPROP_TOOLTIP, StringFormat("Bear Div RSI %.1f→%.1f", ro, rr));
         break;
      }
   }

   // Bullish: prezzo LL, RSI HL
   for(int recent = PivotRightBars + 1; recent < maxScan; recent++)
   {
      if(!IsPivotLow(rates, recent, PivotLeftBars, PivotRightBars)) continue;
      if(recent > DivRecentValidityBars) continue;
      if(rsi[recent] <= 0) continue;
      for(int older = recent + MinSwingDistanceBars;
          older <= MathMin(recent + MaxSwingDistanceBars, maxScan); older++)
      {
         if(!IsPivotLow(rates, older, PivotLeftBars, PivotRightBars)) continue;
         if(rsi[older] <= 0) continue;
         double pr = rates[recent].low, po = rates[older].low;
         double rr = rsi[recent],       ro = rsi[older];
         if(pr >= po - MinPriceSwingDiff) continue;
         if(rr <= ro + MinRSISwingDiff)  continue;
         datetime t1 = iTime(_Symbol, InpSignalTF, older);
         datetime t2 = iTime(_Symbol, InpSignalTF, recent);
         if(t1 == 0 || t2 == 0) break;
         string nm = g_rsiObjPrefix + "DVL_" + IntegerToString(dc++);
         ObjectCreate(0, nm, OBJ_TREND, g_rsiSubWindow, t1, ro, t2, rr);
         ObjectSetInteger(0, nm, OBJPROP_COLOR, clrLime);
         ObjectSetInteger(0, nm, OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, nm, OBJPROP_RAY_RIGHT, false);
         ObjectSetInteger(0, nm, OBJPROP_RAY_LEFT,  false);
         ObjectSetString(0,  nm, OBJPROP_TOOLTIP, StringFormat("Bull Div RSI %.1f→%.1f", ro, rr));
         break;
      }
   }
}

void RSIWindow_DrawRSIMA()
{
   // Disegna la SMA dell'RSI come serie di segmenti OBJ_TREND nella sottofinestra
   // (l'handle RSI viene già disegnato automaticamente da ChartIndicatorAdd)
   if(g_rsiSubWindow < 0) return;
   int total = MathMin(PivotScanBars * 3, 500);
   double rsi[], rsiMa[];
   if(!g_cache.GetRSIData(total, rsi, rsiMa)) return;

   // Disegna segmenti MA come linea continua
   int prev = -1;
   datetime tPrev = 0;
   double maPrev = 0;
   for(int i = total - 1; i >= 1; i--)
   {
      if(rsiMa[i] <= 0 || rsiMa[i] >= EMPTY_VALUE - 1) continue;
      datetime t = iTime(_Symbol, InpSignalTF, i);
      if(t == 0) continue;
      if(tPrev != 0)
      {
         string nm = g_rsiObjPrefix + "MA_" + IntegerToString((int)t);
         ObjectCreate(0, nm, OBJ_TREND, g_rsiSubWindow, tPrev, maPrev, t, rsiMa[i]);
         ObjectSetInteger(0, nm, OBJPROP_COLOR, clrGold);
         ObjectSetInteger(0, nm, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, nm, OBJPROP_RAY_RIGHT, false);
         ObjectSetInteger(0, nm, OBJPROP_RAY_LEFT,  false);
         ObjectSetInteger(0, nm, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetString(0,  nm, OBJPROP_TOOLTIP, StringFormat("RSI MA %.2f", rsiMa[i]));
      }
      tPrev = t;
      maPrev = rsiMa[i];
   }
}

void RSIWindow_Update()
{
   if(!EnableRSIWindow) return;
   datetime curBar = iTime(_Symbol, InpSignalTF, 0);
   if(curBar == g_rsiLastDraw) return;
   g_rsiLastDraw = curBar;

   if(g_rsiSubWindow < 0) RSIWindow_FindSubWindow();
   if(g_rsiSubWindow < 0) { RSIWindow_Init(); return; }

   RSIWindow_DeleteObjects();

   int total = MathMin(PivotScanBars * 3 + 50, 600);
   double rsi[], rsiMa[];
   if(!g_cache.GetRSIData(total, rsi, rsiMa)) return;

   MqlRates rates[];
   if(!g_cache.GetRates(total, rates)) return;

   RSIWindow_DrawRSIMA();
   RSIWindow_DrawCrossMarkers(rsi, rsiMa, (int)ArraySize(rsi));
   RSIWindow_DrawDivergences(rsi, rates, (int)ArraySize(rates));
   ChartRedraw(0);
}

int OnInit()
{
   g_digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   g_point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   g_stopsLevelPoints = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   g_freezeLevelPoints = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_FREEZE_LEVEL);
   
   if(HedgingOnly)
   {
      long mm = AccountInfoInteger(ACCOUNT_MARGIN_MODE);
      g_isHedging = (mm == ACCOUNT_MARGIN_MODE_RETAIL_HEDGING);
      if(!g_isHedging)
      {
         LogEx(LOG_ERROR, "Account must be HEDGING mode", "INIT");
         return INIT_FAILED;
      }
   }
   
   if(!g_cache.Init())
   {
      LogEx(LOG_ERROR, "Failed to initialize data cache", "INIT");
      return INIT_FAILED;
   }
   
   if(!g_tradeMgr.Init())
   {
      LogEx(LOG_ERROR, "Failed to initialize trade manager", "INIT");
      g_cache.Release();
      return INIT_FAILED;
   }
   
   string ymd = TimeToString(TimeCurrent(), TIME_DATE);
   StringReplace(ymd, ".", "-");
   
   if(g_levels.LoadForDate(ymd))
   {
      g_levels.Draw();
      g_tradingEnabled = true;
      LogEx(LOG_INFO, "Loaded " + IntegerToString(g_levels.Count()) + " levels for " + ymd, "INIT");
   }
   else
   {
      g_tradingEnabled = false;
      LogEx(LOG_WARN, "No levels for " + ymd + ", trading disabled until levels available", "INIT");
   }
   
   g_stats.startTime = TimeCurrent();
   EventSetTimer(InpTimerSeconds);
   
   RSIWindow_Init();
   
   return INIT_SUCCEEDED;
}

void OnDeinit(const int reason)
{
   EventKillTimer();
   RSIWindow_Release();
   g_cache.Release();
   g_levels.DeleteObjects();
   
   if(g_stats.tradesOpened > 0)
      g_stats.PrintReport();
   
   LogEx(LOG_INFO, "Deinitialized", "DEINIT");
}

void OnTimer()
{
   string ymd = TimeToString(TimeCurrent(), TIME_DATE);
   StringReplace(ymd, ".", "-");
   
   if(ymd == g_levels.LoadedDate()) return;
   
   // Nuovo giorno: cancella tutti gli oggetti grafici del giorno precedente
   // (linee dei livelli ELS_LVL_ e linee delle trade ELS_TRADE_)
   g_levels.DeleteObjects();
   
   if(!g_levels.LoadForDate(ymd))
   {
      if(TimeCurrent() - g_lastNoLevelsLog > 300)
      {
         LogEx(LOG_WARN, "No levels for " + ymd + ", trading disabled", "TIMER");
         g_lastNoLevelsLog = TimeCurrent();
         g_noLevelsCount++;
      }
      g_tradingEnabled = false;
      return;
   }
   
   g_levels.Draw();
   g_tradingEnabled = true;
   g_lastNoLevelsLog = 0;
   g_noLevelsCount = 0;
   
   LogEx(LOG_INFO, "Loaded " + IntegerToString(g_levels.Count()) + " levels for " + ymd, "TIMER");
}

void OnTick()
{
   if(!g_tradingEnabled || g_levels.Count() < 2)
   {
      if(PositionsTotal() > 0)
         g_tradeMgr.ManagePositions(g_levels, g_cache, g_stats);
      return;
   }
   
   g_stats.UpdateEquity();
   
   // Equity TP: se il profitto flottante supera la soglia, chiudi tutto e ricomincia
   if(CheckEquityTP()) return;
   
   g_tradeMgr.ManagePositions(g_levels, g_cache, g_stats);
   
   // HEDGE safety net: ogni tick verifica ogni posizione aperta senza hedge valido
   // Copre sia hedgeTicket==0 che ticket orfani (plasmaReset da ManageHedgePosition)
   if(UseHedgeProtection)
   {
      for(int _si = 0; _si < (int)ArraySize(g_tradeMgr.m_states); _si++)
      {
         ulong mainTkt = g_tradeMgr.m_states[_si].ticket;
         
         // Posizione principale deve essere ancora aperta
         if(!PositionSelectByTicket(mainTkt)) continue;
         
         // T1 già colpito → hedge non serve più
         if(g_tradeMgr.IsTarget1Hit(mainTkt)) continue;
         
         // Leggi proprietà SUBITO dopo PositionSelectByTicket
         ENUM_DIR mainDir = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? DIR_BUY : DIR_SELL;
         double mainEntry = PositionGetDouble(POSITION_PRICE_OPEN);
         double mainVol   = PositionGetDouble(POSITION_VOLUME);
         
         ulong hTkt = g_tradeMgr.m_states[_si].hedgeTicket;
         
         // Controlla se hedge esiste (senza cambiare la selezione attiva della main)
         bool hedgeExists = false;
         if(hTkt != 0)
         {
            if(OrderSelect(hTkt))       hedgeExists = true;
            else if(PositionSelectByTicket(hTkt)) hedgeExists = true;
            // Ri-seleziona main dopo i check
            PositionSelectByTicket(mainTkt);
         }
         
         LogEx(LOG_DEBUG, StringFormat(
            "HEDGE safety-net check: main=#%I64u hTkt=%I64u exists=%s dir=%s entry=%.2f",
            mainTkt, hTkt, hedgeExists?"Y":"N",
            mainDir==DIR_SELL?"SELL":"BUY", mainEntry), "HEDGE");
         
         if(hedgeExists) continue; // hedge ok, niente da fare
         
         // Hedge mancante o orfano → ripiazza
         double lBuf     = LevelBufferPoints * g_point;
         double hTrigger = 0.0;
         
         if(mainDir == DIR_SELL)
         {
            for(int _lk = 0; _lk < g_levels.Count(); _lk++)
               if(g_levels.Get(_lk) > mainEntry + lBuf) { hTrigger = g_levels.Get(_lk); break; }
         }
         else
         {
            for(int _lk = g_levels.Count()-1; _lk >= 0; _lk--)
               if(g_levels.Get(_lk) < mainEntry - lBuf) { hTrigger = g_levels.Get(_lk); break; }
         }
         
         if(hTrigger > 0)
         {
            ulong newH = PlaceHedgeOrder(mainDir, hTrigger, mainVol);
            g_tradeMgr.m_states[_si].hedgeTicket = newH;
            LogEx(LOG_INFO, StringFormat(
               "HEDGE safety-net RIPIAZZO: old=#%I64u → nuovo #%I64u @ %.2f main=#%I64u ok=%s",
               hTkt, newH, hTrigger, mainTkt, newH>0?"SI":"NO"), "HEDGE");
         }
         else
         {
            LogEx(LOG_WARN, StringFormat(
               "HEDGE safety-net: main=#%I64u nessun trigger level trovato entry=%.2f dir=%s",
               mainTkt, mainEntry, mainDir==DIR_SELL?"SELL":"BUY"), "HEDGE");
         }
      }
   }
   
   RSIWindow_Update();
   
   datetime curBar = iTime(_Symbol, InpSignalTF, 0);
   if(curBar == 0 || curBar == g_lastBarTime) return;
   g_lastBarTime = curBar;
   
   if(!CheckSpreadFilter()) return;
   if(!CheckATRFilter(g_cache)) return;
   
   int needBars = MathMax(300, PivotScanBars + 50);
   
   MqlRates rates[];
   if(!g_cache.GetRates(needBars, rates)) return;
   
   double rsi[], rsiMa[], atr[];
   if(!g_cache.GetRSIData(needBars, rsi, rsiMa)) return;
   if(!g_cache.GetATR(needBars, atr)) return;
   
   string openDate = TimeToString(TimeCurrent(), TIME_DATE);
   StringReplace(openDate, ".", "-");
   
   if(UseSetup_DivergenceReversal)
   {
      SignalResult sig;
      if(CheckDivergenceSignal(g_levels, g_cache, rates, sig))
      {
         g_stats.totalSignals++;
         if(g_tradeMgr.Open(sig, g_levels, g_cache.GetLatestATR(), openDate))
            return;
      }
   }
   
   if(UseSetup_RejectionMomentum)
   {
      SignalResult sig;
      if(CheckRejectionSignal(g_levels, g_cache, sig))
      {
         g_stats.totalSignals++;
         g_tradeMgr.Open(sig, g_levels, g_cache.GetLatestATR(), openDate);
      }
   }
}

void OnTradeTransaction(const MqlTradeTransaction &trans,
                        const MqlTradeRequest &request,
                        const MqlTradeResult &result)
{
   if(trans.type != TRADE_TRANSACTION_DEAL_ADD) return;
   
   ulong deal = trans.deal;
   if(deal == 0) return;
   
   // HistoryDealSelect DEVE essere chiamata prima di qualsiasi HistoryDealGet*
   if(!HistoryDealSelect(deal)) return;
   
   if(HistoryDealGetString(deal, DEAL_SYMBOL) != _Symbol) return;
   if((long)HistoryDealGetInteger(deal, DEAL_MAGIC) != (long)InpMagicNumber) return;
   
   long entry = HistoryDealGetInteger(deal, DEAL_ENTRY);
   if(entry != DEAL_ENTRY_OUT) return;
   
   // Cancella le linee grafiche della trade chiusa (SL broker, TP broker, chiusura manuale)
   if(EnableTradeDrawing)
   {
      ulong posId = HistoryDealGetInteger(deal, DEAL_POSITION_ID);
      if(posId > 0)
      {
         string base = "ELS_TRADE_" + IntegerToString(posId) + "_";
         for(int _i = ObjectsTotal(0) - 1; _i >= 0; _i--)
         {
            string nm = ObjectName(0, _i);
            if(StringFind(nm, base) == 0) ObjectDelete(0, nm);
         }
         ChartRedraw(0);
      }
   }
   
   double profit = HistoryDealGetDouble(deal, DEAL_PROFIT);
   if(profit > 0)
      g_stats.grossProfit += profit;
   else
      g_stats.grossLoss += MathAbs(profit);
   
   g_stats.tradesClosed++;
   
   // HEDGE: scansiona tutti gli stati e controlla se qualche hedgeTicket
   // non esiste più (né come pending né come posizione) → ripiazza
   if(UseHedgeProtection)
   {
      for(int _si = 0; _si < (int)ArraySize(g_tradeMgr.m_states); _si++)
      {
         ulong hTkt = g_tradeMgr.m_states[_si].hedgeTicket;
         if(hTkt == 0) continue;
         
         // Se esiste ancora come pending o posizione → skip
         if(OrderSelect(hTkt) || PositionSelectByTicket(hTkt)) continue;
         
         // Non esiste più → è stato chiuso. La posizione principale è ancora aperta?
         ulong mainTkt = g_tradeMgr.m_states[_si].ticket;
         if(!PositionSelectByTicket(mainTkt)) continue;
         if(g_tradeMgr.IsTarget1Hit(mainTkt)) continue;
         
         // Leggi proprietà PRIMA di qualsiasi altra selezione
         ENUM_DIR mainDir = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? DIR_BUY : DIR_SELL;
         double mainEntry = PositionGetDouble(POSITION_PRICE_OPEN);
         double mainVol   = PositionGetDouble(POSITION_VOLUME);
         double lBuf      = LevelBufferPoints * g_point;
         double hTrigger  = 0.0;
         
         if(mainDir == DIR_SELL)
         {
            for(int _lk = 0; _lk < g_levels.Count(); _lk++)
               if(g_levels.Get(_lk) > mainEntry + lBuf) { hTrigger = g_levels.Get(_lk); break; }
         }
         else
         {
            for(int _lk = g_levels.Count()-1; _lk >= 0; _lk--)
               if(g_levels.Get(_lk) < mainEntry - lBuf) { hTrigger = g_levels.Get(_lk); break; }
         }
         
         if(hTrigger > 0)
         {
            g_tradeMgr.m_states[_si].hedgeTicket = 0;
            ulong newH = PlaceHedgeOrder(mainDir, hTrigger, mainVol);
            g_tradeMgr.m_states[_si].hedgeTicket = newH;
            LogEx(LOG_INFO, StringFormat(
               "HEDGE re-place: #%I64u chiuso → nuovo #%I64u @ %.2f (mainPos=#%I64u ok=%s)",
               hTkt, newH, hTrigger, mainTkt, newH>0?"SI":"NO"), "HEDGE");
         }
         else
         {
            LogEx(LOG_WARN, StringFormat(
               "HEDGE re-place SKIP: #%I64u chiuso ma nessun trigger level trovato entry=%.2f",
               hTkt, mainEntry), "HEDGE");
         }
      }
   }
}
